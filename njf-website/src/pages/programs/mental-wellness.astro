---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---

<BaseLayout title="Mental Wellness Workshops — The N Johnson Foundation">
  <PageHero label="Programs" title="Mental <em>Wellness</em> Workshops" subtitle="Building emotional resilience, self-love, and healthy boundaries — coming soon." />

  <section class="program-detail">
    <div class="detail-inner">
      <div class="detail-content">
        <div class="coming-soon-badge reveal"><i data-lucide="clock"></i> Coming Soon</div>
        <h2 class="detail-heading reveal reveal-delay-1">A child's mind matters as much as their <em>education.</em></h2>
        <p class="detail-body reveal reveal-delay-2">The N Johnson Foundation recognizes that academic success and emotional well-being are deeply connected. A child who is anxious, stressed, or struggling with their sense of self cannot fully engage in learning — no matter how many supplies or scholarships we provide.</p>
        <p class="detail-body reveal reveal-delay-3">That's why we're developing <strong>mental wellness workshops</strong> designed specifically for students and families in Belize. These sessions will focus on emotional resilience, self-love, healthy boundaries, and emotional intelligence — equipping young people with the inner tools they need to thrive, not just survive.</p>

        <h3 class="detail-subhead reveal reveal-delay-3">Planned workshop topics</h3>
        <div class="detail-list reveal reveal-delay-4">
          <div class="detail-item"><i data-lucide="heart"></i><span>Self-love and positive self-image</span></div>
          <div class="detail-item"><i data-lucide="shield"></i><span>Setting and maintaining healthy boundaries</span></div>
          <div class="detail-item"><i data-lucide="brain"></i><span>Emotional intelligence and regulation</span></div>
          <div class="detail-item"><i data-lucide="sparkles"></i><span>Building resilience through adversity</span></div>
          <div class="detail-item"><i data-lucide="users"></i><span>Family communication and support skills</span></div>
        </div>
      </div>

      <div class="detail-sidebar">
        <div class="info-card reveal">
          <h3>Get involved early</h3>
          <p>We're looking for mental health professionals, educators, and community leaders to help shape this program. If you have expertise in youth mental wellness, we'd love to hear from you.</p>
          <a href="/contact" class="btn-bark" style="margin-top:1rem;">Contact us <i data-lucide="arrow-right"></i></a>
        </div>
        <div class="info-card purple reveal reveal-delay-1">
          <h3>Why mental wellness?</h3>
          <p>Our founder Nicole Johnson's background as a Medi-Cal Certified Peer Support Specialist and her work in behavioral health inform our belief that healing and learning go hand in hand.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="program-cta">
    <div class="program-cta-inner reveal">
      <h2>Help us bring this program to <em>life.</em></h2>
      <p>Your support will help fund the development and delivery of mental wellness workshops across Belize.</p>
      <div class="cta-buttons">
        <a href="/donate" class="btn-teal" data-zeffy=""><i data-lucide="heart"></i> Donate now</a>
        <a href="/volunteer" class="btn-bark">Volunteer <i data-lucide="arrow-right"></i></a>
        <a href="/programs" class="btn-text-link">← Back to programs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  [data-lucide] { width: 20px; height: 20px; stroke: var(--teal-deep); flex-shrink: 0; }
  .coming-soon-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--purple-mist); color: var(--purple); font-size: 0.82rem; font-weight: 600; padding: 0.5rem 1.2rem; border-radius: 100px; margin-bottom: 1.5rem; }
  .coming-soon-badge [data-lucide] { width: 16px; height: 16px; stroke: var(--purple); }
  .program-detail { padding: 6rem; background: var(--cream); }
  .detail-inner { display: grid; grid-template-columns: 1.4fr 1fr; gap: 5rem; max-width: 1100px; margin: 0 auto; align-items: start; }
  .detail-heading { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 700; color: var(--bark); line-height: 1.2; margin-bottom: 1.5rem; }
  .detail-heading em { font-style: italic; color: var(--teal-deep); }
  .detail-body { font-size: 1rem; color: var(--bark-mid); line-height: 1.8; margin-bottom: 1.2rem; }
  .detail-body strong { color: var(--bark); font-weight: 600; }
  .detail-subhead { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 700; color: var(--bark); margin: 2rem 0 1rem; }
  .detail-list { display: flex; flex-direction: column; gap: 0.8rem; }
  .detail-item { display: flex; align-items: center; gap: 0.75rem; font-size: 0.92rem; color: var(--bark-mid); }
  .detail-sidebar { display: flex; flex-direction: column; gap: 1.2rem; }
  .info-card { background: var(--sand); border-radius: 20px; padding: 2rem; }
  .info-card.purple { background: var(--purple-mist); }
  .info-card h3 { font-family: var(--font-serif); font-size: 1.05rem; font-weight: 700; color: var(--bark); margin-bottom: 0.8rem; }
  .info-card p { font-size: 0.9rem; color: var(--bark-mid); line-height: 1.7; }
  .program-cta { padding: 5rem; background: var(--bark); text-align: center; }
  .program-cta-inner { max-width: 500px; margin: 0 auto; }
  .program-cta h2 { font-family: var(--font-serif); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: var(--cream); line-height: 1.2; margin-bottom: 0.8rem; }
  .program-cta h2 em { font-style: italic; color: var(--teal-wash); }
  .program-cta p { font-size: 0.95rem; color: rgba(253, 250, 246, 0.6); line-height: 1.7; margin-bottom: 1.5rem; }
  .cta-buttons { display: flex; justify-content: center; gap: 1.2rem; flex-wrap: wrap; align-items: center; }
  @media (max-width: 1024px) { .program-detail, .program-cta { padding: 4rem 2.5rem; } .detail-inner { grid-template-columns: 1fr; gap: 3rem; } }
  @media (max-width: 640px) { .program-detail, .program-cta { padding: 3.5rem 1.5rem; } }
</style>

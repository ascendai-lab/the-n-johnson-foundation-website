---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---

<BaseLayout title="Peer Mentorship — The N Johnson Foundation">
  <PageHero label="Programs" title="Peer <em>Mentorship</em>" subtitle="Trained peer leaders paired with younger students — creating safe spaces for growth." />

  <section class="program-detail">
    <div class="detail-inner">
      <div class="detail-content">
        <h2 class="detail-heading reveal">Young people leading <em>young people.</em></h2>
        <p class="detail-body reveal reveal-delay-1">Sometimes, a young person needs to hear "I understand" from someone close to their own age — someone who's walked a similar path. Our Peer Mentorship program pairs trained student leaders with younger peers, creating <strong>safe, judgment-free spaces</strong> for open conversation, guidance, and emotional support.</p>
        <p class="detail-body reveal reveal-delay-2">Peer mentors receive training in active listening, conflict resolution, emotional intelligence, and boundary-setting. They become trusted figures in their school communities — proof that leadership doesn't require a title, just a willingness to show up for someone else.</p>

        <h3 class="detail-subhead reveal reveal-delay-3">Program pillars</h3>
        <div class="detail-list reveal reveal-delay-3">
          <div class="detail-item"><i data-lucide="check-circle"></i><span>Structured mentor training in emotional support</span></div>
          <div class="detail-item"><i data-lucide="check-circle"></i><span>One-on-one and small group mentoring sessions</span></div>
          <div class="detail-item"><i data-lucide="check-circle"></i><span>Safe space conversations on real student challenges</span></div>
          <div class="detail-item"><i data-lucide="check-circle"></i><span>Leadership development for mentors</span></div>
        </div>
      </div>

      <div class="detail-sidebar">
        <div class="info-card reveal">
          <span class="info-icon"><i data-lucide="users"></i></span>
          <h3>Become a mentor</h3>
          <p>If you're a student leader or young professional who wants to make a difference, we'd love to connect with you about mentorship opportunities.</p>
          <a href="/volunteer" class="btn-bark" style="margin-top:1rem;">Volunteer <i data-lucide="arrow-right"></i></a>
        </div>
        <div class="impact-quote reveal reveal-delay-1">
          <p>"A mentor doesn't have to have all the answers. They just have to show up and listen."</p>
        </div>
      </div>
    </div>
  </section>

  <section class="program-cta">
    <div class="program-cta-inner reveal">
      <h2>Support the next generation of <em>leaders.</em></h2>
      <p>Your donation helps train and support peer mentors in schools across Belize.</p>
      <div class="cta-buttons">
        <a href="/donate" class="btn-teal" data-zeffy=""><i data-lucide="heart"></i> Donate now</a>
        <a href="/programs" class="btn-text-link">← Back to programs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  [data-lucide] { width: 20px; height: 20px; stroke: var(--teal-deep); flex-shrink: 0; }
  .program-detail { padding: 6rem; background: var(--cream); }
  .detail-inner { display: grid; grid-template-columns: 1.4fr 1fr; gap: 5rem; max-width: 1100px; margin: 0 auto; align-items: start; }
  .detail-heading { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 700; color: var(--bark); line-height: 1.2; margin-bottom: 1.5rem; }
  .detail-heading em { font-style: italic; color: var(--teal-deep); }
  .detail-body { font-size: 1rem; color: var(--bark-mid); line-height: 1.8; margin-bottom: 1.2rem; }
  .detail-body strong { color: var(--bark); font-weight: 600; }
  .detail-subhead { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 700; color: var(--bark); margin: 2rem 0 1rem; }
  .detail-list { display: flex; flex-direction: column; gap: 0.8rem; }
  .detail-item { display: flex; align-items: center; gap: 0.75rem; font-size: 0.92rem; color: var(--bark-mid); }
  .detail-sidebar { display: flex; flex-direction: column; gap: 1.2rem; }
  .info-card { background: var(--sand); border-radius: 20px; padding: 2rem; }
  .info-icon { display: block; margin-bottom: 1rem; }
  .info-icon [data-lucide] { width: 32px; height: 32px; stroke: var(--teal-deep); }
  .info-card h3 { font-family: var(--font-serif); font-size: 1.05rem; font-weight: 700; color: var(--bark); margin-bottom: 0.8rem; }
  .info-card p { font-size: 0.9rem; color: var(--bark-mid); line-height: 1.7; }
  .impact-quote { background: var(--teal-mist); border-radius: 20px; padding: 2rem; border-left: 4px solid var(--teal); }
  .impact-quote p { font-family: var(--font-serif); font-style: italic; font-size: 0.95rem; color: var(--bark); line-height: 1.6; }
  .program-cta { padding: 5rem; background: var(--bark); text-align: center; }
  .program-cta-inner { max-width: 500px; margin: 0 auto; }
  .program-cta h2 { font-family: var(--font-serif); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: var(--cream); line-height: 1.2; margin-bottom: 0.8rem; }
  .program-cta h2 em { font-style: italic; color: var(--teal-wash); }
  .program-cta p { font-size: 0.95rem; color: rgba(253, 250, 246, 0.6); line-height: 1.7; margin-bottom: 1.5rem; }
  .cta-buttons { display: flex; justify-content: center; gap: 1.2rem; flex-wrap: wrap; align-items: center; }
  @media (max-width: 1024px) { .program-detail, .program-cta { padding: 4rem 2.5rem; } .detail-inner { grid-template-columns: 1fr; gap: 3rem; } }
  @media (max-width: 640px) { .program-detail, .program-cta { padding: 3.5rem 1.5rem; } }
</style>

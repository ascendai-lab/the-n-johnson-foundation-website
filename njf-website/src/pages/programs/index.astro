---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const programs = [
  { title: 'Student Scholarships', icon: 'graduation-cap', desc: 'Financial assistance ensuring students continue their education without interruption. We directly fund tuition, fees, and materials so families don\'t have to choose between bills and school.', href: '/programs/scholarships', link: 'Learn more →', wash: 'teal' },
  { title: 'School Supply Drives', icon: 'backpack', desc: 'Backpacks, uniforms, books, and essentials distributed directly to students in Belize and the U.S.', href: '/programs/supply-drives', link: 'Learn more →', wash: '' },
  { title: 'Mental Wellness Workshops', icon: 'heart-pulse', desc: 'Upcoming sessions for students and families on emotional resilience, self-love, and healthy boundaries.', href: '/programs/mental-wellness', link: 'Coming soon →', wash: 'purple' },
  { title: 'School Donations', icon: 'school', desc: 'Classroom resources tailored directly to what teachers and students actually need to succeed.', href: '/programs/school-support', link: 'Learn more →', wash: '' },
  { title: 'Peer Mentorship', icon: 'users', desc: 'Trained peer leaders paired with younger students — creating safe, judgment-free spaces for open conversation, guidance, and emotional support.', href: '/programs/peer-mentorship', link: 'Learn more →', wash: '' },
  { title: 'The Book Initiative', icon: 'book-open', desc: 'Proceeds from Nicole Johnson\'s published novels — stories of resilience and healing — fund the Foundation\'s programs directly.', href: 'https://www.amazon.com/author/nicoleswasojohnsonwrites', link: 'Shop on Amazon →', wash: 'teal', external: true },
];
---

<BaseLayout title="Our Programs — The N Johnson Foundation" description="Explore The N Johnson Foundation's programs: scholarships, supply drives, mental wellness workshops, school donations, and peer mentorship.">

  <PageHero
    label="Our Programs"
    title="Programs rooted in <em>real community needs.</em>"
    subtitle="Every program we run starts with listening — to students, families, teachers, and community leaders."
  />

  <section class="programs-landing">
    <div class="programs-grid">
      {programs.map((prog, i) => (
        <a href={prog.href} class={`prog-card reveal reveal-delay-${(i % 3) + 1} ${prog.wash ? `wash-${prog.wash}` : ''}`} {...(prog.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
          <span class="prog-icon"><i data-lucide={prog.icon}></i></span>
          <h3 class="prog-title">{prog.title}</h3>
          <p class="prog-desc">{prog.desc}</p>
          <span class="prog-link">{prog.link}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="programs-cta">
    <div class="programs-cta-inner reveal">
      <h2>Want to support our <em>programs?</em></h2>
      <p>Your donation directly funds scholarships, school supplies, and community programs that change lives.</p>
      <div class="cta-buttons">
        <a href="/donate" class="btn-teal" data-zeffy=""><i data-lucide="heart"></i> Donate now</a>
        <a href="/volunteer" class="btn-bark">Volunteer <i data-lucide="arrow-right"></i></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .prog-icon [data-lucide] { width: 32px; height: 32px; stroke: var(--teal-deep); }
  .wash-purple .prog-icon [data-lucide] { stroke: var(--purple); }

  .programs-landing { padding: 6rem; background: var(--cream); }
  .programs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto; }

  .prog-card { background: var(--sand); border-radius: 24px; padding: 2rem; position: relative; overflow: hidden; transition: transform 0.3s cubic-bezier(.22, .68, 0, 1.2), box-shadow 0.3s; display: block; }
  .prog-card:hover { transform: translateY(-5px); box-shadow: 0 16px 48px rgba(44, 74, 90, 0.10); }

  .wash-teal { background: var(--teal-mist); }
  .wash-purple { background: var(--purple-mist); }

  .prog-icon { display: block; margin-bottom: 1.2rem; line-height: 1; }
  .prog-title { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; color: var(--bark); margin-bottom: 0.6rem; line-height: 1.3; }
  .prog-desc { font-size: 0.88rem; color: var(--bark-mid); line-height: 1.65; margin-bottom: 1rem; }
  .prog-link { font-size: 0.82rem; font-weight: 600; color: var(--teal-deep); }

  .programs-cta { padding: 6rem; background: var(--bark); text-align: center; }
  .programs-cta-inner { max-width: 560px; margin: 0 auto; }
  .programs-cta h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 700; color: var(--cream); line-height: 1.2; margin-bottom: 1rem; }
  .programs-cta h2 em { font-style: italic; color: var(--teal-wash); }
  .programs-cta p { font-size: 1rem; color: rgba(253, 250, 246, 0.6); line-height: 1.7; margin-bottom: 2rem; }
  .cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

  @media (max-width: 1024px) {
    .programs-landing, .programs-cta { padding: 4rem 2.5rem; }
    .programs-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .programs-landing, .programs-cta { padding: 3.5rem 1.5rem; }
    .programs-grid { grid-template-columns: 1fr; }
  }
</style>

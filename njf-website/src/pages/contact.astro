---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Contact — The N Johnson Foundation" description="Get in touch with The N Johnson Foundation. We'd love to hear from you.">
  <PageHero label="Get in Touch" title="We'd love to <em>hear from you.</em>" subtitle="Whether you have a question, want to volunteer, or are interested in partnering — reach out." />

  <section class="contact-section">
    <div class="contact-inner">
      <div class="contact-form-wrap">
        <h2 class="form-heading reveal">Send us a <em>message.</em></h2>
        <form name="contact" method="POST" data-netlify="true" class="contact-form reveal reveal-delay-1">
          <input type="hidden" name="form-name" value="contact" />
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your full name" />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="you@example.com" />
            </div>
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" required placeholder="What is this about?" />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" required placeholder="Tell us more..."></textarea>
          </div>
          <button type="submit" class="btn-teal"><i data-lucide="send"></i> Send message</button>
        </form>
      </div>

      <div class="contact-sidebar">
        <div class="contact-card reveal">
          <span class="contact-icon"><i data-lucide="map-pin"></i></span>
          <h3>Address</h3>
          <p>24325 Crenshaw Blvd<br />Unit #1031<br />Torrance, CA 90505</p>
        </div>
        <div class="contact-card reveal reveal-delay-1">
          <span class="contact-icon"><i data-lucide="phone"></i></span>
          <h3>Phone</h3>
          <p><a href="tel:3236782112">323-678-2112</a></p>
        </div>
        <div class="contact-card reveal reveal-delay-2">
          <span class="contact-icon"><i data-lucide="clock"></i></span>
          <h3>Response Time</h3>
          <p>We typically respond within 1–2 business days.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  [data-lucide] { width: 20px; height: 20px; stroke: var(--teal-deep); flex-shrink: 0; }
  .contact-icon [data-lucide] { width: 24px; height: 24px; }

  .contact-section { padding: 6rem; background: var(--cream); }
  .contact-inner { display: grid; grid-template-columns: 1.5fr 1fr; gap: 4rem; max-width: 1000px; margin: 0 auto; align-items: start; }

  .form-heading { font-family: var(--font-serif); font-size: clamp(1.6rem, 3vw, 2rem); font-weight: 700; color: var(--bark); line-height: 1.2; margin-bottom: 2rem; }
  .form-heading em { font-style: italic; color: var(--teal-deep); }

  .contact-form { display: flex; flex-direction: column; gap: 1.2rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.85rem; font-weight: 500; color: var(--bark); }
  .form-group input, .form-group textarea {
    font-family: var(--font-sans); font-size: 0.92rem; color: var(--bark);
    background: var(--sand); border: 1px solid var(--sand-dark); border-radius: 12px;
    padding: 0.85rem 1rem; outline: none; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-group input:focus, .form-group textarea:focus {
    border-color: var(--teal); box-shadow: 0 0 0 3px rgba(46, 169, 155, 0.15);
  }
  .form-group textarea { resize: vertical; min-height: 120px; }

  .contact-sidebar { display: flex; flex-direction: column; gap: 1.2rem; }
  .contact-card { background: var(--sand); border-radius: 20px; padding: 1.8rem; }
  .contact-icon { display: block; margin-bottom: 0.8rem; }
  .contact-card h3 { font-family: var(--font-serif); font-size: 1rem; font-weight: 700; color: var(--bark); margin-bottom: 0.5rem; }
  .contact-card p { font-size: 0.9rem; color: var(--bark-mid); line-height: 1.6; }
  .contact-card a { color: var(--teal-deep); font-weight: 500; }

  @media (max-width: 1024px) {
    .contact-section { padding: 4rem 2.5rem; }
    .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
    .contact-sidebar { flex-direction: row; flex-wrap: wrap; }
    .contact-card { flex: 1; min-width: 200px; }
  }
  @media (max-width: 640px) {
    .contact-section { padding: 3.5rem 1.5rem; }
    .form-row { grid-template-columns: 1fr; }
    .contact-sidebar { flex-direction: column; }
  }
</style>

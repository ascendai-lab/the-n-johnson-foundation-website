---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="About Us — The N Johnson Foundation" description="Learn about The N Johnson Foundation, our mission to support education and mental wellness in Belize and the United States, and meet our founders.">

  <PageHero
    label="About Us"
    title="Built on belief. Driven by <em>purpose.</em>"
    subtitle="The N Johnson Foundation is a community-driven nonprofit supporting children and families through education, emotional wellness, and direct community support."
  />

  <!-- ══ MISSION ══ -->
  <section class="mission-section">
    <div class="mission-inner">
      <div class="mission-left">
        <div class="section-label reveal">Our Mission</div>
        <h2 class="section-heading reveal reveal-delay-1">
          A child cannot learn when they are hungry, afraid, or <em>unseen.</em>
        </h2>
      </div>
      <div class="mission-right">
        <p class="body-text reveal reveal-delay-1">
          The N. Johnson Foundation was established with a simple but powerful conviction: <strong>every child deserves the tools, support, and emotional safety to thrive in school and in life.</strong>
        </p>
        <p class="body-text reveal reveal-delay-2">
          We work to ease financial burdens on families, promote emotional wellness, and make sure every student walks into school prepared — with supplies in hand and support in their corner. Our work spans <strong>Belize and the United States</strong>, rooted in culturally respectful, community-first solutions that address both practical needs and long-term healing.
        </p>
        <p class="body-text reveal reveal-delay-3">
          Through generous support from book sales and community donations, we fund scholarships, supply drives, school donations, and emerging mental wellness programs — directly reaching the students and families who need it most.
        </p>
      </div>
    </div>
  </section>

  <!-- ══ VALUES ══ -->
  <section class="values-section">
    <div class="values-inner">
      <div class="section-label reveal">What We Stand For</div>
      <h2 class="section-heading reveal reveal-delay-1">Our <em>values</em> guide everything.</h2>
      <div class="values-grid">
        <div class="value-card reveal reveal-delay-1">
          <span class="value-icon"><i data-lucide="heart-pulse"></i></span>
          <h3>Mental Wellness</h3>
          <p>We believe emotional health is the foundation of learning. A supported child is a child who can grow.</p>
        </div>
        <div class="value-card reveal reveal-delay-2">
          <span class="value-icon"><i data-lucide="graduation-cap"></i></span>
          <h3>Educational Equity</h3>
          <p>Every student — regardless of zip code or income — deserves access to quality education and the supplies to succeed.</p>
        </div>
        <div class="value-card reveal reveal-delay-3">
          <span class="value-icon"><i data-lucide="heart"></i></span>
          <h3>Self-Love &amp; Boundaries</h3>
          <p>We teach young people that caring for themselves is not selfish — it's essential. Healthy boundaries create healthy communities.</p>
        </div>
        <div class="value-card reveal reveal-delay-1">
          <span class="value-icon"><i data-lucide="users"></i></span>
          <h3>Community First</h3>
          <p>We don't bring solutions from the outside. We listen, learn, and build programs that respect the communities we serve.</p>
        </div>
        <div class="value-card reveal reveal-delay-2">
          <span class="value-icon"><i data-lucide="sparkles"></i></span>
          <h3>Youth Empowerment</h3>
          <p>Young people are not just beneficiaries — they are leaders, mentors, and changemakers in their own right.</p>
        </div>
        <div class="value-card reveal reveal-delay-3">
          <span class="value-icon"><i data-lucide="brain"></i></span>
          <h3>Emotional Intelligence</h3>
          <p>We foster the skills to understand, express, and manage emotions — equipping young people for life beyond the classroom.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FOUNDERS ══ -->
  <section class="founders-section" id="founders">
    <div class="founders-inner">
      <div class="founder-card reveal">
        <div class="founder-img-wrap">
          <img src="/images/founder-nicole.jpg" alt="Nicole Johnson, MHA" class="founder-img" />
        </div>
        <div class="founder-info">
          <h3>Nicole Johnson, MHA</h3>
          <span class="founder-role">Founder &amp; Executive Director</span>
          <p>Nicole Johnson is a U.S. Veteran, published author, and Medi-Cal Certified Peer Support Specialist with a Master of Healthcare Administration. Her years in behavioral health — combined with her own lived experience — give her a rare ability to bridge systems thinking with deep human compassion.</p>
          <p>Her published novels, centered on themes of resilience and healing, directly fund the Foundation's programs — creating a unique model where storytelling fuels real-world change.</p>
          <div class="founder-creds">
            <span class="cred">MHA · Master of Healthcare Administration</span>
            <span class="cred">CPSS Certified</span>
            <span class="cred">U.S. Veteran</span>
            <span class="cred">Published Author</span>
          </div>
        </div>
      </div>

      <div class="founder-card reveal reveal-delay-2">
        <div class="founder-img-wrap founder-img-placeholder">
          <span class="founder-initials"><i data-lucide="scale"></i></span>
        </div>
        <div class="founder-info">
          <h3>Monica Stuart, Esq.</h3>
          <span class="founder-role">Co-Founder &amp; Attorney-at-Law</span>
          <p>Monica Stuart brings governance, compliance, and advocacy expertise to the Foundation — ensuring it operates with transparency, accountability, and an unwavering ethical foundation. Her legal acumen and passion for community justice make her an essential pillar of the organization's leadership.</p>
          <div class="founder-creds">
            <span class="cred">Attorney-at-Law</span>
            <span class="cred">Governance &amp; Compliance</span>
            <span class="cred">Advocacy</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ BELIZE ══ -->
  <section class="belize-about-section" id="belize">
    <div class="belize-about-inner">
      <div class="belize-about-left">
        <div class="section-label reveal">Where We Serve</div>
        <h2 class="section-heading reveal reveal-delay-1">Our heart is in <em>Belize</em> — and growing.</h2>
        <p class="body-text reveal reveal-delay-2">
          The Foundation was born from a deep personal connection to Belizean communities where educational access and financial hardship prevent talented, eager children from reaching their potential.
        </p>
        <p class="body-text reveal reveal-delay-3">
          We show up with culturally respectful, community-first solutions — not charity, but solidarity. From our base in Torrance, California, we raise funds, build partnerships, and coordinate programs that flow directly to the students and schools that need them most.
        </p>
        <div class="reveal reveal-delay-4" style="margin-top:2rem;">
          <a href="/donate" class="btn-bark">Support our work <i data-lucide="arrow-right"></i></a>
        </div>
      </div>
      <div class="belize-about-right">
        <div class="belize-stat-card reveal reveal-delay-1">
          <div class="belize-stat-num">30<span>+</span></div>
          <div class="belize-stat-label">Students supported with backpacks &amp; materials</div>
        </div>
        <div class="belize-stat-card reveal reveal-delay-2">
          <div class="belize-stat-num">6</div>
          <div class="belize-stat-label">Scholarships awarded to Belizean students</div>
        </div>
        <div class="belize-stat-card reveal reveal-delay-3">
          <div class="belize-stat-num">2</div>
          <div class="belize-stat-label">Countries actively served</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CTA ══ -->
  <section class="about-cta">
    <div class="about-cta-inner reveal">
      <h2>Ready to make a <em>difference?</em></h2>
      <p>Whether you donate, volunteer, or partner with us — every action helps a child show up to school ready to learn.</p>
      <div class="about-cta-buttons">
        <a href="/donate" class="btn-teal"><i data-lucide="heart"></i> Donate now</a>
        <a href="/volunteer" class="btn-bark">Volunteer <i data-lucide="arrow-right"></i></a>
        <a href="/contact" class="btn-text-link">Get in touch <i data-lucide="arrow-right"></i></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .value-icon [data-lucide] { width: 28px; height: 28px; stroke: var(--teal-deep); }

  .founder-img-placeholder [data-lucide] { width: 48px; height: 48px; stroke: var(--purple); }

  .mission-section { padding: 6rem; background: var(--cream); }
  .mission-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 5rem; align-items: start; }
  .mission-left {}
  .mission-right {}

  .section-heading { font-family: var(--font-serif); font-size: clamp(1.9rem, 3vw, 2.6rem); font-weight: 700; color: var(--bark); line-height: 1.2; letter-spacing: -0.3px; margin-bottom: 1.4rem; }
  .section-heading em { font-style: italic; color: var(--teal-deep); }

  .body-text { font-size: 1rem; color: var(--bark-mid); line-height: 1.8; margin-bottom: 1.2rem; }
  .body-text strong { color: var(--bark); font-weight: 600; }

  .values-section { padding: 6rem; background: var(--sand); }
  .values-inner { max-width: 1000px; margin: 0 auto; }
  .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
  .value-card { background: var(--cream); border-radius: 20px; padding: 2rem; transition: transform 0.3s, box-shadow 0.3s; }
  .value-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(44, 74, 90, 0.08); }
  .value-icon { display: block; margin-bottom: 1rem; }
  .value-card h3 { font-family: var(--font-serif); font-size: 1.05rem; font-weight: 700; color: var(--bark); margin-bottom: 0.6rem; }
  .value-card p { font-size: 0.88rem; color: var(--bark-mid); line-height: 1.65; }

  .founders-section { padding: 6rem; background: var(--cream); }
  .founders-inner { max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; gap: 3rem; }
  .founder-card { display: grid; grid-template-columns: 240px 1fr; gap: 3rem; align-items: start; background: var(--sand); border-radius: 24px; padding: 2.5rem; }
  .founder-img-wrap { width: 200px; height: 200px; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
  .founder-img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .founder-img-placeholder { background: linear-gradient(145deg, var(--purple-mist), var(--sand-dark)); display: flex; align-items: center; justify-content: center; }
  .founder-initials { font-family: var(--font-serif); font-size: 2.5rem; font-weight: 700; color: var(--purple); }
  .founder-info h3 { font-family: var(--font-serif); font-size: 1.3rem; font-weight: 700; color: var(--bark); margin-bottom: 0.3rem; }
  .founder-role { font-size: 0.85rem; color: var(--teal-deep); font-weight: 500; display: block; margin-bottom: 1rem; }
  .founder-info p { font-size: 0.92rem; color: var(--bark-mid); line-height: 1.75; margin-bottom: 0.8rem; }
  .founder-creds { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
  .cred { background: var(--cream); border: 1px solid var(--sand-dark); border-radius: 8px; padding: 0.35rem 0.8rem; font-size: 0.76rem; font-weight: 500; color: var(--bark-mid); }

  .belize-about-section { padding: 6rem; background: var(--sand); }
  .belize-about-inner { display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; }
  .belize-about-right { display: flex; flex-direction: column; gap: 1.2rem; }
  .belize-stat-card { background: var(--cream); border-radius: 20px; padding: 2rem; transition: transform 0.25s; }
  .belize-stat-card:hover { transform: translateX(4px); }
  .belize-stat-num { font-family: var(--font-serif); font-size: 2.5rem; font-weight: 700; color: var(--teal-deep); line-height: 1; margin-bottom: 0.5rem; }
  .belize-stat-num span { color: var(--teal); font-size: 1.5rem; }
  .belize-stat-label { font-size: 0.88rem; color: var(--bark-mid); line-height: 1.5; }

  .about-cta { padding: 6rem; background: var(--bark); text-align: center; }
  .about-cta-inner { max-width: 600px; margin: 0 auto; }
  .about-cta h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 700; color: var(--cream); line-height: 1.2; margin-bottom: 1rem; }
  .about-cta h2 em { font-style: italic; color: var(--teal-wash); }
  .about-cta p { font-size: 1rem; color: rgba(253, 250, 246, 0.6); line-height: 1.7; margin-bottom: 2rem; }
  .about-cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

  @media (max-width: 1024px) {
    .mission-section, .values-section, .founders-section, .belize-about-section, .about-cta { padding: 4rem 2.5rem; }
    .mission-inner { grid-template-columns: 1fr; gap: 2rem; }
    .values-grid { grid-template-columns: 1fr 1fr; }
    .founder-card { grid-template-columns: 1fr; text-align: center; }
    .founder-img-wrap { margin: 0 auto; }
    .founder-creds { justify-content: center; }
    .belize-about-inner { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .mission-section, .values-section, .founders-section, .belize-about-section, .about-cta { padding: 3.5rem 1.5rem; }
    .values-grid { grid-template-columns: 1fr; }
    .founder-card { padding: 1.5rem; }
    .founder-img-wrap { width: 160px; height: 160px; }
    .about-cta-buttons { flex-direction: column; align-items: center; }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { sanityFetch, urlFor } from '../lib/sanity';

const events = await sanityFetch<any[]>(`*[_type == "event"] | order(order asc) {
  eventName, slug, date, description, coverPhoto,
  photos[]{image, alt, caption}
}`);

const fallbackPhotos = [
  { src: '/images/gallery/community-meeting.jpg', alt: 'Building relationships with school leaders in Belize City', caption: 'Building relationships with school leaders in Belize City', position: 'center center' },
  { src: '/images/gallery/students-backpacks.jpg', alt: 'Students pick up their new backpacks during a supply drive', caption: 'Students pick up their new backpacks during a supply drive' },
  { src: '/images/gallery/classroom-visit.jpg', alt: 'Visiting classrooms and connecting with students firsthand', caption: 'Visiting classrooms and connecting with students firsthand' },
  { src: '/images/gallery/teacher-with-students.jpg', alt: 'A teacher guides students through the supply distribution', caption: 'A teacher guides students through the supply distribution' },
  { src: '/images/gallery/students-lineup.jpg', alt: 'Students eagerly await their new supplies', caption: 'Students eagerly await their new supplies', position: 'center center' },
  { src: '/images/gallery/book-donation.jpg', alt: "Donating copies of Nicole's novels to the school library", caption: "Donating copies of Nicole's novels to the school library" },
  { src: '/images/gallery/unpacking-supplies.jpg', alt: 'Unpacking supplies with the school administration team', caption: 'Unpacking supplies with the school administration team' },
  { src: '/images/gallery/reviewing-journals.jpg', alt: 'Reviewing journals and educational materials before distribution', caption: 'Reviewing journals and educational materials before distribution' },
  { src: '/images/gallery/holding-books.jpg', alt: 'Smiles all around — books and backpacks ready to change lives', caption: 'Smiles all around — books and backpacks ready to change lives' },
];

const hasEvents = events && events.length > 0;

// Build a flat photos array for the lightbox (all events combined)
const allPhotos = hasEvents
  ? events.flatMap(event =>
      (event.photos || []).map(photo => ({
        src: photo.image ? urlFor(photo.image).width(1200).url() : '',
        thumb: photo.image ? urlFor(photo.image).width(800).url() : '',
        alt: photo.alt || event.eventName || '',
        caption: photo.caption || '',
      }))
    )
  : fallbackPhotos.map(p => ({ ...p, thumb: p.src }));

// Format date helper
function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Track photo index offset per event for lightbox linking
let photoIndexOffset = 0;
---

<BaseLayout title="Nonprofit Community Events | N Johnson Foundation" description="Photos and highlights from The N Johnson Foundation's supply drives, school visits, and community programs in Belize.">

  <PageHero
    label="Events"
    title="See the <em>impact</em> in action."
    subtitle="Moments from our supply drives, school visits, and community programs in Belize."
  />

  {hasEvents ? (
    <!-- ══ EVENTS LIST ══ -->
    <section class="events-section">
      {events.map((event, eventIdx) => {
        const eventPhotos = event.photos || [];
        const startIndex = photoIndexOffset;
        photoIndexOffset += eventPhotos.length;
        const coverSrc = event.coverPhoto
          ? urlFor(event.coverPhoto).width(1200).url()
          : (eventPhotos[0]?.image ? urlFor(eventPhotos[0].image).width(1200).url() : '/images/gallery/community-meeting.jpg');
        const coverAlt = event.coverPhoto?.alt || event.eventName || '';

        return (
          <div class="event-block reveal">
            <!-- Event Header -->
            <div class="event-header">
              <div class="event-meta">
                {event.date && <span class="event-date"><i data-lucide="calendar"></i> {formatDate(event.date)}</span>}
              </div>
              <h2 class="event-title">{event.eventName}</h2>
              {event.description && <p class="event-description">{event.description}</p>}
            </div>

            <!-- Cover Photo -->
            <div class="event-cover" data-lightbox={startIndex}>
              <img src={coverSrc} alt={coverAlt} loading={eventIdx === 0 ? 'eager' : 'lazy'} />
              <div class="event-cover-overlay">
                <span class="event-photo-count"><i data-lucide="images"></i> {eventPhotos.length} photos</span>
              </div>
            </div>

            <!-- Photo Grid -->
            {eventPhotos.length > 0 && (
              <div class="event-photos-grid">
                {eventPhotos.map((photo, i) => {
                  const photoSrc = photo.image ? urlFor(photo.image).width(800).url() : '';
                  return (
                    <div class={`event-photo-item ${i === 0 ? 'featured' : ''} reveal reveal-delay-${Math.min((i % 4) + 1, 3)}`}>
                      <div class="gallery-img-wrap" data-lightbox={startIndex + i}>
                        <img src={photoSrc} alt={photo.alt || ''} loading="lazy" />
                        <div class="gallery-overlay">
                          <span class="gallery-zoom"><i data-lucide="maximize-2"></i></span>
                        </div>
                      </div>
                      {photo.caption && <p class="gallery-caption">{photo.caption}</p>}
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        );
      })}
    </section>
  ) : (
    <!-- ══ FALLBACK GALLERY ══ -->
    <section class="gallery-section">
      <div class="gallery-inner">
        {fallbackPhotos.map((photo, i) => (
          <div class={`gallery-item ${i === 0 || i === 5 ? 'featured' : ''} reveal ${i > 0 ? `reveal-delay-${((i % 4) || 1)}` : ''}`}>
            <div class="gallery-img-wrap" data-lightbox={i}>
              <img src={photo.src} alt={photo.alt || ''} loading={i < 4 ? 'eager' : 'lazy'} style={photo.position ? `object-position: ${photo.position}` : ''} />
              <div class="gallery-overlay">
                <span class="gallery-zoom"><i data-lucide="maximize-2"></i></span>
              </div>
            </div>
            <p class="gallery-caption">{photo.caption || ''}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ══ LIGHTBOX ══ -->
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close lightbox"><i data-lucide="x"></i></button>
    <button class="lightbox-prev" aria-label="Previous photo"><i data-lucide="chevron-left"></i></button>
    <button class="lightbox-next" aria-label="Next photo"><i data-lucide="chevron-right"></i></button>
    <div class="lightbox-img-wrap">
      <img id="lightbox-img" src="" alt="" />
    </div>
    <p id="lightbox-caption" class="lightbox-caption"></p>
    <span id="lightbox-counter" class="lightbox-counter"></span>
  </div>

  <!-- ══ CTA ══ -->
  <section class="gallery-cta">
    <div class="gallery-cta-inner reveal">
      <h2>Help us fill more <em>backpacks.</em></h2>
      <p>Every photo here represents a child whose day just got a little brighter. Your support makes the next supply drive possible.</p>
      <div class="gallery-cta-buttons">
        <a href="/donate" class="btn-teal" data-zeffy=""><i data-lucide="heart"></i> Donate now</a>
        <a href="/volunteer" class="btn-bark">Volunteer <i data-lucide="arrow-right"></i></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  [data-lucide] { width: 20px; height: 20px; stroke: currentColor; }

  /* ── Events Section ── */
  .events-section { padding: 4rem; background: var(--cream); }

  .event-block {
    max-width: 1100px;
    margin: 0 auto 5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid var(--sand-dark);
  }

  .event-block:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .event-header {
    margin-bottom: 2rem;
  }

  .event-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }

  .event-date {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--teal-deep);
    background: var(--teal-mist);
    padding: 0.4rem 1rem;
    border-radius: 100px;
  }

  .event-date [data-lucide] {
    width: 15px;
    height: 15px;
  }

  .event-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--bark);
    line-height: 1.2;
    margin-bottom: 0.8rem;
  }

  .event-description {
    font-size: 1rem;
    color: var(--bark-mid);
    line-height: 1.75;
    max-width: 700px;
  }

  /* ── Cover Photo ── */
  .event-cover {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    cursor: pointer;
    aspect-ratio: 21 / 9;
  }

  .event-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .event-cover:hover img {
    transform: scale(1.03);
  }

  .event-cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(44, 74, 90, 0.5) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1.5rem;
  }

  .event-photo-count {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.45rem 1rem;
    border-radius: 100px;
  }

  .event-photo-count [data-lucide] {
    width: 15px;
    height: 15px;
  }

  /* ── Event Photos Grid ── */
  .event-photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .event-photo-item.featured {
    grid-column: span 2;
  }

  /* ── Shared Gallery Styles ── */
  .gallery-section { padding: 5rem 4rem; background: var(--cream); }
  .gallery-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .gallery-item.featured {
    grid-column: span 2;
  }

  .gallery-img-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 4 / 3;
  }

  .gallery-item.featured .gallery-img-wrap,
  .event-photo-item.featured .gallery-img-wrap {
    aspect-ratio: 16 / 10;
  }

  .gallery-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-img-wrap:hover img {
    transform: scale(1.04);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(44, 74, 90, 0.45) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .gallery-img-wrap:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-zoom {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--bark);
  }

  .gallery-zoom [data-lucide] {
    width: 16px;
    height: 16px;
  }

  .gallery-caption {
    font-size: 0.85rem;
    color: var(--bark-mid);
    line-height: 1.5;
    margin-top: 0.65rem;
    padding: 0 0.25rem;
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(10, 20, 28, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-img-wrap {
    max-width: 85vw;
    max-height: 72vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img-wrap img {
    max-width: 100%;
    max-height: 72vh;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
    transform: scale(0.95);
    transition: transform 0.3s;
  }

  .lightbox.active .lightbox-img-wrap img {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .lightbox-close:hover { background: rgba(255, 255, 255, 0.2); }
  .lightbox-close:focus-visible { outline: 2px solid var(--teal); outline-offset: 2px; }

  .lightbox-prev, .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.75);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .lightbox-prev { left: 1.5rem; }
  .lightbox-next { right: 1.5rem; }
  .lightbox-prev:hover, .lightbox-next:hover { background: rgba(255, 255, 255, 0.18); }
  .lightbox-prev:focus-visible, .lightbox-next:focus-visible { outline: 2px solid var(--teal); outline-offset: 2px; }

  .lightbox-caption {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    text-align: center;
    margin-top: 1.2rem;
    max-width: 500px;
    line-height: 1.5;
  }

  .lightbox-counter {
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.78rem;
    margin-top: 0.5rem;
    letter-spacing: 0.05em;
  }

  /* ── CTA ── */
  .gallery-cta { padding: 5rem; background: var(--bark); text-align: center; }
  .gallery-cta-inner { max-width: 550px; margin: 0 auto; }
  .gallery-cta h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 700; color: var(--cream); line-height: 1.2; margin-bottom: 1rem; }
  .gallery-cta h2 em { font-style: italic; color: var(--teal-wash); }
  .gallery-cta p { font-size: 0.95rem; color: rgba(253, 250, 246, 0.6); line-height: 1.7; margin-bottom: 2rem; }
  .gallery-cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .events-section { padding: 3rem 2.5rem; }
    .event-photos-grid { grid-template-columns: repeat(2, 1fr); }
    .event-photo-item.featured { grid-column: span 2; }
    .gallery-section { padding: 4rem 2.5rem; }
    .gallery-inner { grid-template-columns: repeat(2, 1fr); }
    .gallery-item.featured { grid-column: span 2; }
    .gallery-cta { padding: 4rem 2.5rem; }
  }

  @media (max-width: 640px) {
    .events-section { padding: 2.5rem 1.25rem; }
    .event-cover { aspect-ratio: 16 / 9; }
    .event-photos-grid { grid-template-columns: 1fr; gap: 1rem; }
    .event-photo-item.featured { grid-column: span 1; }
    .event-photo-item.featured .gallery-img-wrap { aspect-ratio: 4 / 3; }
    .gallery-section { padding: 3rem 1.25rem; }
    .gallery-inner { grid-template-columns: 1fr; gap: 1.25rem; }
    .gallery-item.featured { grid-column: span 1; }
    .gallery-item.featured .gallery-img-wrap { aspect-ratio: 4 / 3; }
    .gallery-cta { padding: 3.5rem 1.5rem; }
    .lightbox-prev, .lightbox-next { width: 40px; height: 40px; }
    .lightbox-prev { left: 0.75rem; }
    .lightbox-next { right: 0.75rem; }
  }
</style>

<script is:inline>
(function() {
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  const lbCaption = document.getElementById('lightbox-caption');
  const lbCounter = document.getElementById('lightbox-counter');
  const items = document.querySelectorAll('[data-lightbox]');
  let current = 0;
  const total = items.length;

  const photos = Array.from(items).map(function(el) {
    const img = el.querySelector('img');
    const caption = el.closest('.gallery-item, .event-photo-item, .event-cover');
    const captionEl = caption ? caption.querySelector('.gallery-caption') : null;
    return { src: img.src, alt: img.alt, caption: captionEl ? captionEl.textContent : '' };
  });

  function show(idx) {
    current = (idx + total) % total;
    lbImg.src = photos[current].src;
    lbImg.alt = photos[current].alt;
    lbCaption.textContent = photos[current].caption;
    lbCounter.textContent = (current + 1) + ' / ' + total;
    lightbox.classList.add('active');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function hide() {
    lightbox.classList.remove('active');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  items.forEach(function(el) {
    el.addEventListener('click', function() { show(parseInt(el.getAttribute('data-lightbox'))); });
  });

  lightbox.querySelector('.lightbox-close').addEventListener('click', hide);
  lightbox.querySelector('.lightbox-prev').addEventListener('click', function() { show(current - 1); });
  lightbox.querySelector('.lightbox-next').addEventListener('click', function() { show(current + 1); });

  lightbox.addEventListener('click', function(e) { if (e.target === lightbox) hide(); });

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') hide();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
})();
</script>

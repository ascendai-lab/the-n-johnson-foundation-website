---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The N Johnson Foundation — Education & Mental Wellness">

  <!-- ══ HERO ══ -->
  <section class="hero" id="home">
    <div class="hero-backdrop"></div>
    <div class="blob-teal"></div>
    <div class="blob-purple"></div>
    <div class="hero-dots"></div>

    <div class="hero-left">
      <div class="hero-kicker rise d1">
        <span class="kicker-line"></span>
        Youth Education &amp; Mental Wellness
      </div>

      <h1 class="hero-heading rise d2">
        Every child<br />
        deserves to <em>thrive</em>,<br />
        not just <span class="hand">survive.</span>
      </h1>

      <p class="hero-body rise d3">
        The N Johnson Foundation removes educational and financial barriers for children and families in Belize and the
        United States — so every student can show up prepared, supported, and ready to grow.
      </p>

      <div class="hero-ctas rise d4">
        <a href="/donate" class="btn-bark">Support a student <i data-lucide="arrow-up-right"></i></a>
        <a href="/programs" class="btn-text-link">See our programs <i data-lucide="arrow-right"></i></a>
      </div>
    </div>

    <div class="hero-right">
      <div class="spinning-badge rise d3">
        <svg viewBox="0 0 80 80" width="80" height="80">
          <defs>
            <path id="circ" d="M 40,40 m -28,0 a 28,28 0 1,1 56,0 a 28,28 0 1,1 -56,0" />
          </defs>
          <text font-size="8.5" fill="#2EA99B" font-family="'DM Sans', sans-serif" font-weight="500" letter-spacing="2">
            <textPath href="#circ">Belize · USA · Community · Education ·</textPath>
          </text>
          <circle cx="40" cy="40" r="5" fill="#2EA99B" />
        </svg>
      </div>

      <div class="photo-frame rise d2">
        <img
          src="/images/hero-nicole.png"
          alt="Nicole Johnson, Founder of The N Johnson Foundation"
          class="hero-real-img"
        />
      </div>

      <div class="sticker sticker-1 rise d4">
        <span class="sticker-icon"><i data-lucide="backpack"></i></span>
        <div class="sticker-text">
          <strong>30+ students</strong>
          supported this school year
        </div>
      </div>

      <div class="sticker sticker-2 rise d5">
        <span class="sticker-icon"><i data-lucide="graduation-cap"></i></span>
        <div class="sticker-text">
          <strong>6 scholarships</strong>
          awarded in Belize
        </div>
      </div>
    </div>
  </section>

  <!-- ══ RIBBON ══ -->
  <div class="ribbon">
    <div class="ribbon-track">
      <span class="ribbon-item">Youth Education <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Mental Wellness <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Belize &amp; United States <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Scholarships <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">School Supply Drives <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Community Support <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Emotional Resilience <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Self-Love &amp; Boundaries <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Youth Education <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Mental Wellness <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Belize &amp; United States <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Scholarships <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">School Supply Drives <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Community Support <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Emotional Resilience <span class="ribbon-sep">✦</span></span>
      <span class="ribbon-item">Self-Love &amp; Boundaries <span class="ribbon-sep">✦</span></span>
    </div>
  </div>

  <!-- ══ INTRO ══ -->
  <section class="intro" id="about-intro">
    <div>
      <div class="section-label reveal">Our Purpose</div>
      <h2 class="intro-title reveal reveal-delay-1">
        Education &amp; <em>healing</em><br />go hand in hand.
      </h2>
    </div>
    <div class="intro-right">
      <p class="intro-body reveal reveal-delay-1">
        The N. Johnson Foundation is a community-driven nonprofit built on the belief that <strong>a child cannot learn
          when they are hungry, afraid, or unseen.</strong> We work to ease financial burdens on families, promote
        emotional wellness, and make sure every student walks into school prepared — with supplies in hand and support
        in their corner.
      </p>
      <p class="intro-body reveal reveal-delay-2">
        Our work spans Belize and the United States, rooted in culturally respectful, community-first solutions that
        address both <strong>practical needs</strong> and <strong>long-term healing.</strong>
      </p>
      <div class="intro-values reveal reveal-delay-3">
        <span class="value-chip">Mental Wellness</span>
        <span class="value-chip">Educational Equity</span>
        <span class="value-chip">Self-Love</span>
        <span class="value-chip">Healthy Boundaries</span>
        <span class="value-chip">Youth Empowerment</span>
        <span class="value-chip">Community First</span>
        <span class="value-chip">Emotional Intelligence</span>
      </div>
    </div>
  </section>

  <!-- ══ PROGRAMS ══ -->
  <section class="programs" id="programs">
    <div class="programs-bg-blob"></div>
    <div class="programs-header">
      <div class="section-label reveal">What We Do</div>
      <h2 class="reveal reveal-delay-1">
        Programs rooted in<br />
        <em>real community needs.</em>
      </h2>
    </div>

    <div class="programs-grid">
      <div class="prog-card prog-card-a prog-card-wash-teal reveal">
        <span class="prog-icon"><i data-lucide="graduation-cap"></i></span>
        <div class="prog-title">Student Scholarships</div>
        <div class="prog-desc">Financial assistance ensuring students continue their education without interruption. We directly fund tuition, fees, and materials so families don't have to choose between bills and school.</div>
        <a href="/programs/scholarships" class="prog-link">Learn more →</a>
      </div>

      <div class="prog-card prog-card-b reveal reveal-delay-1">
        <span class="prog-icon"><i data-lucide="backpack"></i></span>
        <div class="prog-title">School Supply Drives</div>
        <div class="prog-desc">Backpacks, uniforms, books, and essentials distributed directly to students in Belize and the U.S.</div>
        <a href="/programs/supply-drives" class="prog-link">Learn more →</a>
      </div>

      <div class="prog-card prog-card-c prog-card-wash-purple reveal reveal-delay-2">
        <span class="prog-icon"><i data-lucide="heart-pulse"></i></span>
        <div class="prog-title">Mental Wellness Workshops</div>
        <div class="prog-desc">Upcoming sessions for students and families on emotional resilience, self-love, and healthy boundaries.</div>
        <a href="/programs/mental-wellness" class="prog-link">Coming soon →</a>
      </div>

      <div class="prog-card prog-card-d reveal reveal-delay-1">
        <span class="prog-icon"><i data-lucide="school"></i></span>
        <div class="prog-title">School Donations</div>
        <div class="prog-desc">Classroom resources tailored directly to what teachers and students actually need to succeed.</div>
        <a href="/programs/school-support" class="prog-link">Learn more →</a>
      </div>

      <div class="prog-card prog-card-e reveal reveal-delay-2">
        <span class="prog-icon"><i data-lucide="users"></i></span>
        <div class="prog-title">Peer Mentorship</div>
        <div class="prog-desc">Trained peer leaders paired with younger students — creating safe, judgment-free spaces for open conversation, guidance, and emotional support.</div>
        <a href="/programs/peer-mentorship" class="prog-link">Learn more →</a>
      </div>

      <div class="prog-card prog-card-f prog-card-wash-teal reveal reveal-delay-3">
        <span class="prog-icon"><i data-lucide="book-open"></i></span>
        <div class="prog-title">The Book Initiative</div>
        <div class="prog-desc">Proceeds from Nicole Johnson's published novels — stories of resilience and healing — fund the Foundation's programs directly.</div>
        <a href="https://www.amazon.com/author/nicoleswasojohnsonwrites" target="_blank" rel="noopener noreferrer" class="prog-link">Shop on Amazon →</a>
      </div>
    </div>
  </section>

  <!-- ══ IMPACT ══ -->
  <section class="impact" id="impact">
    <div class="impact-blob"></div>
    <div class="impact-blob-2"></div>
    <div class="impact-inner">
      <div>
        <div class="section-label section-label-dark reveal">Our Impact to Date</div>
        <h2 class="reveal reveal-delay-1">
          Small foundation.<br /><em>Real lives changed.</em>
        </h2>
        <p class="impact-body reveal reveal-delay-2">
          Despite being in its early stages, The N. Johnson Foundation has already made <strong>meaningful, measurable
            contributions</strong> to students and communities in Belize. Every number below represents a child who
          showed up to school this year because someone believed in them.
        </p>
        <a href="/donate" class="btn-teal reveal reveal-delay-3">Be part of the next chapter <i data-lucide="arrow-right"></i></a>
      </div>
      <div class="impact-numbers reveal reveal-delay-2">
        <div class="impact-num-card">
          <div class="i-num">30<span>+</span></div>
          <div class="i-label">Students received backpacks &amp; classroom materials this school year</div>
        </div>
        <div class="impact-num-card purple-top">
          <div class="i-num">6</div>
          <div class="i-label">Scholarships, school bags &amp; essential supplies awarded to students</div>
        </div>
        <div class="impact-num-card slate-top">
          <div class="i-num">2</div>
          <div class="i-label">Countries actively served — Belize &amp; United States</div>
        </div>
        <div class="impact-num-card">
          <div class="i-num" style="color:var(--teal-wash)">∞</div>
          <div class="i-label">Potential unlocked when a child feels supported</div>
        </div>
        <div class="impact-num-card wide-card">
          <div style="flex-shrink:0;">
            <div class="i-num" style="font-size:1.8rem; color:var(--cream)">Muslim<br />Community<br />School</div>
          </div>
          <div class="wide-divider"></div>
          <div class="wide-note">Our primary school partner in Belize — recipient of <strong>direct classroom donations</strong>, scholarship support, and supply drives for both students and teachers.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ BELIZE ══ -->
  <section class="belize" id="belize">
    <div class="belize-left">
      <div class="belize-card reveal">
        <div class="belize-flag-wrap"><i data-lucide="map-pin"></i></div>
        <div class="belize-card-title">Belize, Central America</div>
        <div class="belize-card-sub">Our primary home of service</div>
        <div class="belize-row">
          <span class="belize-row-icon"><i data-lucide="school"></i></span>
          <div class="belize-row-text">
            <strong>Muslim Community School</strong>
            Primary partner — scholarships, supply drives &amp; direct school donations
          </div>
        </div>
        <div class="belize-row">
          <span class="belize-row-icon"><i data-lucide="heart-handshake"></i></span>
          <div class="belize-row-text">
            <strong>Families in need</strong>
            Working directly with underserved families to reduce educational barriers
          </div>
        </div>
        <div class="belize-row">
          <span class="belize-row-icon"><i data-lucide="sprout"></i></span>
          <div class="belize-row-text">
            <strong>Mental wellness — coming soon</strong>
            Workshops for students &amp; families planned for expansion
          </div>
        </div>
      </div>
    </div>

    <div class="belize-right">
      <div class="section-label reveal">Where We Serve</div>
      <h2 class="belize-title reveal reveal-delay-1">
        Our heart is<br />in <em>Belize</em> —<br />and growing.
      </h2>
      <p class="belize-body reveal reveal-delay-2">
        The Foundation was born from a deep personal connection to Belizean communities where educational access and
        financial hardship prevent talented, eager children from reaching their potential. We show up with culturally
        respectful, community-first solutions — not charity, but solidarity.
      </p>
      <p class="belize-body reveal reveal-delay-3">
        From our base in Torrance, California, we raise funds, build partnerships, and coordinate programs that flow
        directly to the students and schools that need them most.
      </p>
      <div class="reveal reveal-delay-4" style="margin-top:1.8rem;">
        <a href="/donate" class="btn-bark">Support Belize <i data-lucide="arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ══ FOUNDERS ══ -->
  <section class="founder" id="about">
    <div class="founder-blob"></div>
    <div class="founder-inner">
      <div class="founder-portrait-wrap reveal">
        <div class="founder-portrait">
          <img
            src="/images/founder-nicole.jpg"
            alt="Nicole Johnson, MHA – Founder of The N Johnson Foundation"
            class="founder-real-img"
          />
          <div class="founder-portrait-label" style="position:absolute; bottom:1.5rem; left:0; right:0; background:rgba(248,250,252,0.92); padding:0.75rem 1rem; text-align:center;">
            Nicole Johnson, MHA
            <em>Founder &amp; Executive Director</em>
          </div>
        </div>
        <div class="cofounder-pill">
          <span class="cofounder-icon"><i data-lucide="scale"></i></span>
          <span><strong>Monica Stuart</strong>, Attorney-at-Law · Co-Founder</span>
        </div>
      </div>

      <div class="founder-content">
        <div class="section-label reveal">Our Founders</div>
        <h2 class="founder-title reveal reveal-delay-1">
          Led by <em>lived experience.</em><br />Driven by purpose.
        </h2>
        <p class="founder-bio reveal reveal-delay-2">
          <strong>Nicole Johnson</strong> is a U.S. Veteran, published author, and Medi-Cal Certified Peer Support
          Specialist with a Master of Healthcare Administration. Her years in behavioral health — combined with her own
          lived experience — give her a rare ability to bridge systems thinking with deep human compassion.
        </p>
        <p class="founder-bio reveal reveal-delay-3">
          <strong>Monica Stuart</strong>, Attorney-at-Law and Co-Founder, brings governance, compliance, and advocacy
          expertise — ensuring the Foundation operates with transparency, accountability, and an unwavering ethical
          foundation.
        </p>
        <div class="creds reveal reveal-delay-3">
          <span class="cred">MHA · Master of Healthcare Administration</span>
          <span class="cred">CPSS Certified</span>
          <span class="cred">U.S. Veteran</span>
          <span class="cred">Published Author</span>
          <span class="cred">Attorney-at-Law</span>
        </div>
        <div class="reveal reveal-delay-4">
          <a href="/about" class="btn-bark">More about our team <i data-lucide="arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ DONATE ══ -->
  <section class="donate-section" id="donate">
    <div class="donate-band">
      <div class="donate-left">
        <div class="section-label reveal">Get Involved</div>
        <h2 class="donate-title reveal reveal-delay-1">
          Help a child focus on<br />
          <em>learning, not hardship.</em>
        </h2>
        <p class="donate-body reveal reveal-delay-2">
          Your donation directly funds scholarships, school supplies, and community programs that promote both learning
          and emotional well-being. Every contribution — large or small — means a child shows up to school with what
          they need.
        </p>
        <div class="donate-actions reveal reveal-delay-3">
          <a href="/donate" class="btn-teal"><i data-lucide="heart"></i> Donate now</a>
          <a href="https://www.amazon.com/author/nicoleswasojohnsonwrites" target="_blank" rel="noopener noreferrer" class="btn-text-link"><i data-lucide="book-open"></i> Buy a book →</a>
        </div>
      </div>
      <div class="donate-right">
        <div class="donate-reason reveal reveal-delay-1">
          <span class="donate-reason-icon"><i data-lucide="backpack"></i></span>
          <div class="donate-reason-text">
            <strong>$25 — School supplies for one child</strong>
            A backpack, notebook, and pens so a student walks in prepared and proud.
          </div>
        </div>
        <div class="donate-reason reveal reveal-delay-2">
          <span class="donate-reason-icon"><i data-lucide="graduation-cap"></i></span>
          <div class="donate-reason-text">
            <strong>$100 — Scholarship contribution</strong>
            Helps cover fees so a family isn't forced to pull their child from school.
          </div>
        </div>
        <div class="donate-reason reveal reveal-delay-3">
          <span class="donate-reason-icon"><i data-lucide="school"></i></span>
          <div class="donate-reason-text">
            <strong>$250 — Classroom resource bundle</strong>
            Books, materials &amp; tools donated directly to a school in Belize.
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ─────────────────────────────────────────
     HERO IMAGE STYLES
  ───────────────────────────────────────── */
  .hero-real-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: inherit;
    position: relative;
    z-index: 1;
  }

  .founder-real-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: inherit;
    display: block;
  }

  .founder-portrait-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--bark-mid);
    line-height: 1.5;
  }

  .founder-portrait-label em {
    font-size: 0.76rem;
    color: var(--bark-light);
    font-style: italic;
    display: block;
    margin-top: 0.1rem;
  }

  /* ─────────────────────────────────────────
     LUCIDE ICON SIZING (page-specific)
  ───────────────────────────────────────── */
  .prog-icon [data-lucide] { width: 32px; height: 32px; stroke: var(--teal-deep); }
  .prog-card-b .prog-icon [data-lucide],
  .prog-card-wash-purple .prog-icon [data-lucide] { stroke: var(--purple); }
  .prog-card-d .prog-icon [data-lucide] { stroke: var(--slate); }
  .prog-card-f .prog-icon [data-lucide] { stroke: var(--teal-deep); }
  .sticker-icon [data-lucide] { width: 26px; height: 26px; stroke: var(--teal-deep); }
  .belize-row-icon [data-lucide] { width: 22px; height: 22px; stroke: var(--teal-deep); }
  .donate-reason-icon [data-lucide] { width: 24px; height: 24px; stroke: var(--teal-deep); }
  .donate-reason:nth-child(2) .donate-reason-icon [data-lucide] { stroke: var(--purple); }
  .donate-reason:nth-child(3) .donate-reason-icon [data-lucide] { stroke: var(--slate); }
  .belize-flag-wrap [data-lucide] { width: 36px; height: 36px; stroke: var(--teal-deep); margin: auto; }
  .cofounder-icon [data-lucide] { width: 14px; height: 14px; stroke: var(--purple); flex-shrink: 0; }
</style>

<style>
  /* ─────────────────────────────────────────
     HERO
  ───────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    padding-top: 80px;
    display: grid;
    grid-template-columns: 55% 45%;
    position: relative;
    overflow: hidden;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--cream);
    z-index: 0;
  }

  .hero-backdrop::after {
    content: '';
    position: absolute;
    bottom: 0; right: 0;
    width: 65%; height: 100%;
    background: var(--sand);
    clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
  }

  .blob-teal {
    position: absolute; width: 380px; height: 380px;
    background: radial-gradient(circle, var(--teal-wash) 0%, transparent 70%);
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    top: 8%; left: -6%; opacity: 0.55;
    animation: blobMorph 12s ease-in-out infinite;
    pointer-events: none;
  }

  .blob-purple {
    position: absolute; width: 260px; height: 260px;
    background: radial-gradient(circle, var(--purple-mist) 0%, transparent 70%);
    border-radius: 40% 60% 45% 55% / 55% 40% 60% 45%;
    bottom: 10%; left: 30%; opacity: 0.5;
    animation: blobMorph 15s ease-in-out infinite reverse;
    pointer-events: none;
  }

  .hero-dots {
    position: absolute; top: 20%; right: 42%;
    width: 120px; height: 160px;
    background-image: radial-gradient(circle, var(--bark-light) 1.5px, transparent 1.5px);
    background-size: 14px 14px;
    opacity: 0.18; pointer-events: none;
  }

  .hero-left {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; justify-content: center;
    padding: 5rem 4rem 5rem 6rem;
  }

  .hero-kicker {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-size: 0.78rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--teal-deep); margin-bottom: 1.8rem;
  }

  .kicker-line { width: 32px; height: 1.5px; background: var(--teal); border-radius: 2px; }

  h1.hero-heading {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 4.5vw, 4rem);
    font-weight: 700; line-height: 1.12;
    color: var(--bark); margin-bottom: 1.6rem; letter-spacing: -0.5px;
  }
  h1.hero-heading em { font-style: italic; color: var(--teal-deep); }
  h1.hero-heading .hand { font-style: italic; color: var(--purple); }

  .hero-body {
    font-size: 1.05rem; color: var(--bark-mid);
    max-width: 460px; line-height: 1.75; margin-bottom: 2.8rem;
  }

  .hero-ctas { display: flex; align-items: center; gap: 1.4rem; flex-wrap: wrap; }

  .hero-right {
    position: relative; z-index: 2;
    display: flex; align-items: center; justify-content: center;
    padding: 4rem 4rem 4rem 2rem;
  }

  .photo-frame {
    width: 340px; aspect-ratio: 3/4;
    background: var(--sand-dark);
    border-radius: 55% 45% 48% 52% / 42% 52% 48% 58%;
    position: relative;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(44, 74, 90, 0.12);
  }

  .photo-frame::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(160deg, var(--teal-mist) 0%, var(--sand-dark) 50%, var(--purple-mist) 100%);
    opacity: 0.7;
  }

  .sticker {
    position: absolute; background: var(--cream);
    border-radius: 18px; box-shadow: 0 8px 32px rgba(44, 74, 90, 0.10);
    padding: 1rem 1.25rem; display: flex; align-items: center; gap: 0.8rem;
  }
  .sticker-1 { top: 18%; right: -2rem; animation: gentleFloat 7s ease-in-out infinite; }
  .sticker-2 { bottom: 22%; left: -3rem; animation: gentleFloat 9s ease-in-out infinite 1.5s; }
  .sticker-text { font-size: 0.78rem; color: var(--bark-mid); line-height: 1.35; }
  .sticker-text strong { display: block; font-size: 0.88rem; color: var(--bark); font-weight: 600; margin-bottom: 0.1rem; }

  .spinning-badge { position: absolute; top: 12%; left: -2.5rem; width: 80px; height: 80px; }
  .spinning-badge svg { animation: slowSpin 20s linear infinite; }

  /* ── RIBBON ── */

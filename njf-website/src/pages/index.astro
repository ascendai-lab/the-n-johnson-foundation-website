---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityFetch, urlFor, toHtml } from '../lib/sanity';

const page = await sanityFetch<any>(`*[_type == "homePage"][0]{
  ...,
  "programs": *[_type == "program"] | order(order asc) {
    title, slug, shortDescription, icon, linkLabel, externalUrl, isComingSoon, wash
  }
}`);

const settings = await sanityFetch<any>(`*[_type == "siteSettings"][0]{
  amazonBookLink, zeffyDonationUrl
}`);

const founders = await sanityFetch<any>(`*[_type == "teamMember"] | order(order asc) {
  name, credentials, role, photo, bio, credentialTags
}`);

const defaultRibbonItems = [
  'Youth Education', 'Mental Wellness', 'Belize & United States', 'Scholarships',
  'School Supply Drives', 'Community Support', 'Emotional Resilience', 'Self-Love & Boundaries'
];
const ribbonItems = page?.ribbonItems?.length ? page.ribbonItems : defaultRibbonItems;

const defaultIntroValues = [
  'Mental Wellness', 'Educational Equity', 'Self-Love', 'Healthy Boundaries',
  'Youth Empowerment', 'Community First', 'Emotional Intelligence'
];
const introValues = page?.introValues?.length ? page.introValues : defaultIntroValues;

const defaultImpactNumbers = [
  { value: '30', suffix: '+', label: 'Students received backpacks & classroom materials this school year', topColor: '' },
  { value: '6', suffix: '', label: 'Scholarships, school bags & essential supplies awarded to students', topColor: 'purple-top' },
  { value: '2', suffix: '', label: 'Countries actively served — Belize & United States', topColor: 'slate-top' },
  { value: '∞', suffix: '', label: 'Potential unlocked when a child feels supported', topColor: '', customColor: 'var(--teal-wash)' },
];
const impactNumbers = page?.impactNumbers?.length ? page.impactNumbers : defaultImpactNumbers;

const defaultBelizeHighlights = [
  { icon: 'school', title: 'Muslim Community School', description: 'Primary partner — scholarships, supply drives & direct school donations' },
  { icon: 'heart-handshake', title: 'Families in need', description: 'Working directly with underserved families to reduce educational barriers' },
  { icon: 'sprout', title: 'Mental wellness — coming soon', description: 'Workshops for students & families planned for expansion' },
];
const belizeHighlights = page?.belizeHighlights?.length ? page.belizeHighlights : defaultBelizeHighlights;

const defaultDonationReasons = [
  { icon: 'backpack', title: '$25 — School supplies for one child', description: 'A backpack, notebook, and pens so a student walks in prepared and proud.' },
  { icon: 'graduation-cap', title: '$100 — Scholarship contribution', description: 'Helps cover fees so a family isn\'t forced to pull their child from school.' },
  { icon: 'school', title: '$250 — Classroom resource bundle', description: 'Books, materials & tools donated directly to a school in Belize.' },
];
const donationReasons = page?.donationReasons?.length ? page.donationReasons : defaultDonationReasons;

const nicole = founders?.[0];
const monica = founders?.[1];

const amazonLink = settings?.amazonBookLink || 'https://www.amazon.com/author/nicoleswasojohnsonwrites';

const defaultIntroBody = '<p class="intro-body reveal reveal-delay-1">The N. Johnson Foundation is a community-driven nonprofit built on the belief that <strong>a child cannot learn when they are hungry, afraid, or unseen.</strong> We work to ease financial burdens on families, promote emotional wellness, and make sure every student walks into school prepared — with supplies in hand and support in their corner.</p><p class="intro-body reveal reveal-delay-2">Our work spans Belize and the United States, rooted in culturally respectful, community-first solutions that address both <strong>practical needs</strong> and <strong>long-term healing.</strong></p>';
---

<BaseLayout title={page?.metaTitle || "The N Johnson Foundation — Education & Mental Wellness"} description={page?.metaDescription || undefined}>

  <!-- ══ HERO ══ -->
  <section class="hero" id="home">
    <div class="hero-backdrop"></div>
    <div class="blob-teal"></div>
    <div class="blob-purple"></div>
    <div class="hero-dots"></div>

    <div class="hero-left">
      <div class="hero-kicker rise d1">
        <span class="kicker-line"></span>
        {page?.heroLabel || 'Youth Education & Mental Wellness'}
      </div>

      <h1 class="hero-heading rise d2" set:html={page?.heroHeading || 'Every child<br />deserves to <em>thrive</em>,<br />not just <span class="hand">survive.</span>'} />

      <p class="hero-body rise d3">
        {page?.heroBody || 'The N Johnson Foundation removes educational and financial barriers for children and families in Belize and the United States — so every student can show up prepared, supported, and ready to grow.'}
      </p>

      <div class="hero-ctas rise d4">
        <a href="/donate" class="btn-bark">{page?.heroCtaLabel || 'Support a student'} <i data-lucide="arrow-up-right"></i></a>
        <a href="/programs" class="btn-text-link">{page?.heroSecondaryCtaLabel || 'See our programs'} <i data-lucide="arrow-right"></i></a>
      </div>
    </div>

    <div class="hero-right">
      <div class="spinning-badge rise d3">
        <svg viewBox="0 0 80 80" width="80" height="80">
          <defs>
            <path id="circ" d="M 40,40 m -28,0 a 28,28 0 1,1 56,0 a 28,28 0 1,1 -56,0" />
          </defs>
          <text font-size="8.5" fill="#2EA99B" font-family="'DM Sans', sans-serif" font-weight="500" letter-spacing="2">
            <textPath href="#circ">{page?.badgeText || 'Belize · USA · Community · Education ·'}</textPath>
          </text>
          <circle cx="40" cy="40" r="5" fill="#2EA99B" />
        </svg>
      </div>

      <div class="photo-frame rise d2">
        <img
          src={page?.heroImage ? urlFor(page.heroImage).width(680).url() : '/images/hero-nicole.png'}
          alt={page?.heroImageAlt || 'Nicole Johnson, Founder of The N Johnson Foundation'}
          class="hero-real-img"
        />
      </div>

      <div class="sticker sticker-1 rise d4">
        <span class="sticker-icon"><i data-lucide={page?.sticker1Icon || 'backpack'}></i></span>
        <div class="sticker-text">
          <strong>{page?.sticker1Title || '30+ students'}</strong>
          {page?.sticker1Text || 'supported this school year'}
        </div>
      </div>

      <div class="sticker sticker-2 rise d5">
        <span class="sticker-icon"><i data-lucide={page?.sticker2Icon || 'graduation-cap'}></i></span>
        <div class="sticker-text">
          <strong>{page?.sticker2Title || '6 scholarships'}</strong>
          {page?.sticker2Text || 'awarded in Belize'}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ RIBBON ══ -->
  <div class="ribbon">
    <div class="ribbon-track">
      {ribbonItems.map((item) => (
        <span class="ribbon-item">{typeof item === 'string' ? item : item.text || item} <span class="ribbon-sep">✦</span></span>
      ))}
      {ribbonItems.map((item) => (
        <span class="ribbon-item">{typeof item === 'string' ? item : item.text || item} <span class="ribbon-sep">✦</span></span>
      ))}
    </div>
  </div>

  <!-- ══ INTRO ══ -->
  <section class="intro" id="about-intro">
    <div>
      <div class="section-label reveal">{page?.introLabel || 'Our Purpose'}</div>
      <h2 class="intro-title reveal reveal-delay-1" set:html={page?.introHeading || 'Education &amp; <em>healing</em><br />go hand in hand.'} />
    </div>
    <div class="intro-right body-text">
      {page?.introBody ? <Fragment set:html={toHtml(page.introBody)} /> : <Fragment set:html={defaultIntroBody} />}
      <div class="intro-values reveal reveal-delay-3">
        {introValues.map((val) => (
          <span class="value-chip">{typeof val === 'string' ? val : val.text || val}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ PROGRAMS ══ -->
  <section class="programs" id="programs">
    <div class="programs-bg-blob"></div>
    <div class="programs-header">
      <div class="section-label reveal">{page?.programsLabel || 'What We Do'}</div>
      <h2 class="reveal reveal-delay-1" set:html={page?.programsHeading || 'Programs rooted in<br /><em>real community needs.</em>'} />
    </div>

    <div class="programs-grid">
      {page?.programs?.length ? page.programs.map((prog, i) => {
        const washClass = prog.wash === 'teal' ? 'prog-card-wash-teal' : prog.wash === 'purple' ? 'prog-card-wash-purple' : '';
        const gridClasses = ['prog-card-a','prog-card-b','prog-card-c','prog-card-d','prog-card-e','prog-card-f'];
        const href = prog.externalUrl || `/programs/${prog.slug?.current}`;
        const target = prog.externalUrl ? '_blank' : undefined;
        return (
          <div class={`prog-card ${gridClasses[i] || ''} ${washClass} reveal ${i > 0 ? 'reveal-delay-' + Math.min(i, 3) : ''}`}>
            <span class="prog-icon"><i data-lucide={prog.icon}></i></span>
            <div class="prog-title">{prog.title}</div>
            <div class="prog-desc">{prog.shortDescription}</div>
            <a href={href} target={target} rel={target ? 'noopener noreferrer' : undefined} class="prog-link">{prog.linkLabel || 'Learn more'} →</a>
          </div>
        );
      }) : (
        <Fragment>
          <div class="prog-card prog-card-a prog-card-wash-teal reveal">
            <span class="prog-icon"><i data-lucide="graduation-cap"></i></span>
            <div class="prog-title">Student Scholarships</div>
            <div class="prog-desc">Financial assistance ensuring students continue their education without interruption. We directly fund tuition, fees, and materials so families don't have to choose between bills and school.</div>
            <a href="/programs/scholarships" class="prog-link">Learn more →</a>
          </div>
          <div class="prog-card prog-card-b reveal reveal-delay-1">
            <span class="prog-icon"><i data-lucide="backpack"></i></span>
            <div class="prog-title">School Supply Drives</div>
            <div class="prog-desc">Backpacks, uniforms, books, and essentials distributed directly to students in Belize and the U.S.</div>
            <a href="/programs/supply-drives" class="prog-link">Learn more →</a>
          </div>
          <div class="prog-card prog-card-c prog-card-wash-purple reveal reveal-delay-2">
            <span class="prog-icon"><i data-lucide="heart-pulse"></i></span>
            <div class="prog-title">Mental Wellness Workshops</div>
            <div class="prog-desc">Upcoming sessions for students and families on emotional resilience, self-love, and healthy boundaries.</div>
            <a href="/programs/mental-wellness" class="prog-link">Coming soon →</a>
          </div>
          <div class="prog-card prog-card-d reveal reveal-delay-1">
            <span class="prog-icon"><i data-lucide="school"></i></span>
            <div class="prog-title">School Donations</div>
            <div class="prog-desc">Classroom resources tailored directly to what teachers and students actually need to succeed.</div>
            <a href="/programs/school-support" class="prog-link">Learn more →</a>
          </div>
          <div class="prog-card prog-card-e reveal reveal-delay-2">
            <span class="prog-icon"><i data-lucide="users"></i></span>
            <div class="prog-title">Peer Mentorship</div>
            <div class="prog-desc">Trained peer leaders paired with younger students — creating safe, judgment-free spaces for open conversation, guidance, and emotional support.</div>
            <a href="/programs/peer-mentorship" class="prog-link">Learn more →</a>
          </div>
          <div class="prog-card prog-card-f prog-card-wash-teal reveal reveal-delay-3">
            <span class="prog-icon"><i data-lucide="book-open"></i></span>
            <div class="prog-title">The Book Initiative</div>
            <div class="prog-desc">Proceeds from Nicole Johnson's published novels — stories of resilience and healing — fund the Foundation's programs directly.</div>
            <a href={amazonLink} target="_blank" rel="noopener noreferrer" class="prog-link">Shop on Amazon →</a>
          </div>
        </Fragment>
      )}
    </div>
  </section>

  <!-- ══ IMPACT ══ -->
  <section class="impact" id="impact">
    <div class="impact-blob"></div>
    <div class="impact-blob-2"></div>
    <div class="impact-inner">
      <div>
        <div class="section-label section-label-dark reveal">{page?.impactLabel || 'Our Impact to Date'}</div>
        <h2 class="reveal reveal-delay-1" set:html={page?.impactHeading || 'Small foundation.<br /><em>Real lives changed.</em>'} />
        <p class="impact-body reveal reveal-delay-2" set:html={page?.impactBody || 'Despite being in its early stages, The N. Johnson Foundation has already made <strong>meaningful, measurable contributions</strong> to students and communities in Belize. Every number below represents a child who showed up to school this year because someone believed in them.'} />
        <a href="/donate" class="btn-teal reveal reveal-delay-3">{page?.impactCtaLabel || 'Be part of the next chapter'} <i data-lucide="arrow-right"></i></a>
      </div>
      <div class="impact-numbers reveal reveal-delay-2">
        {impactNumbers.map((item) => (
          <div class={`impact-num-card ${item.topColor || ''}`}>
            <div class="i-num" style={item.customColor ? `color:${item.customColor}` : undefined}>{item.value}{item.suffix ? <span>{item.suffix}</span> : null}</div>
            <div class="i-label">{item.label}</div>
          </div>
        ))}
        <div class="impact-num-card wide-card">
          <div style="flex-shrink:0;">
            <div class="i-num" style="font-size:1.8rem; color:var(--cream)" set:html={page?.impactWideCardTitle || 'Muslim<br />Community<br />School'} />
          </div>
          <div class="wide-divider"></div>
          <div class="wide-note" set:html={page?.impactWideCardNote || 'Our primary school partner in Belize — recipient of <strong>direct classroom donations</strong>, scholarship support, and supply drives for both students and teachers.'} />
        </div>
      </div>
    </div>
  </section>

  <!-- ══ BELIZE ══ -->
  <section class="belize" id="belize">
    <div class="belize-left">
      <div class="belize-card reveal">
        <div class="belize-flag-wrap"><i data-lucide="map-pin"></i></div>
        <div class="belize-card-title">{page?.belizeCardTitle || 'Belize, Central America'}</div>
        <div class="belize-card-sub">{page?.belizeCardSub || 'Our primary home of service'}</div>
        {belizeHighlights.map((row) => (
          <div class="belize-row">
            <span class="belize-row-icon"><i data-lucide={row.icon}></i></span>
            <div class="belize-row-text">
              <strong>{row.title}</strong>
              {row.description}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="belize-right">
      <div class="section-label reveal">{page?.belizeLabel || 'Where We Serve'}</div>
      <h2 class="belize-title reveal reveal-delay-1" set:html={page?.belizeHeading || 'Our heart is<br />in <em>Belize</em> —<br />and growing.'} />
      <p class="belize-body reveal reveal-delay-2">
        {page?.belizeBody1 || 'The Foundation was born from a deep personal connection to Belizean communities where educational access and financial hardship prevent talented, eager children from reaching their potential. We show up with culturally respectful, community-first solutions — not charity, but solidarity.'}
      </p>
      <p class="belize-body reveal reveal-delay-3">
        {page?.belizeBody2 || 'From our base in Torrance, California, we raise funds, build partnerships, and coordinate programs that flow directly to the students and schools that need them most.'}
      </p>
      <div class="reveal reveal-delay-4" style="margin-top:1.8rem;">
        <a href="/donate" class="btn-bark">{page?.belizeCtaLabel || 'Support Belize'} <i data-lucide="arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ══ FOUNDERS ══ -->
  <section class="founder" id="about">
    <div class="founder-blob"></div>
    <div class="founder-inner">
      <div class="founder-portrait-wrap reveal">
        <div class="founder-portrait">
          <img
            src={nicole?.photo ? urlFor(nicole.photo).width(600).url() : '/images/founder-nicole.jpg'}
            alt={nicole ? `${nicole.name}${nicole.credentials ? ', ' + nicole.credentials : ''} – Founder of The N Johnson Foundation` : 'Nicole Johnson, MHA – Founder of The N Johnson Foundation'}
            class="founder-real-img"
          />
          <div class="founder-portrait-label" style="position:absolute; bottom:1.5rem; left:0; right:0; background:rgba(248,250,252,0.92); padding:0.75rem 1rem; text-align:center;">
            {nicole ? `${nicole.name}${nicole.credentials ? ', ' + nicole.credentials : ''}` : 'Nicole Johnson, MHA'}
            <em>{nicole?.role || 'Founder & Executive Director'}</em>
          </div>
        </div>
        <div class="cofounder-pill">
          <span class="cofounder-icon"><i data-lucide="scale"></i></span>
          <span><strong>{monica?.name || 'Monica Stuart'}</strong>, {monica?.credentials || 'Attorney-at-Law'} · {monica?.role || 'Co-Founder'}</span>
        </div>
      </div>

      <div class="founder-content">
        <div class="section-label reveal">{page?.foundersLabel || 'Our Founders'}</div>
        <h2 class="founder-title reveal reveal-delay-1" set:html={page?.foundersHeading || 'Led by <em>lived experience.</em><br />Driven by purpose.'} />
        {nicole?.bio ? (
          <div class="founder-bio reveal reveal-delay-2" set:html={toHtml(nicole.bio)} />
        ) : (
          <p class="founder-bio reveal reveal-delay-2">
            <strong>Nicole Johnson</strong> is a U.S. Veteran, published author, and Medi-Cal Certified Peer Support
            Specialist with a Master of Healthcare Administration. Her years in behavioral health — combined with her own
            lived experience — give her a rare ability to bridge systems thinking with deep human compassion.
          </p>
        )}
        {monica?.bio ? (
          <div class="founder-bio reveal reveal-delay-3" set:html={toHtml(monica.bio)} />
        ) : (
          <p class="founder-bio reveal reveal-delay-3">
            <strong>Monica Stuart</strong>, Attorney-at-Law and Co-Founder, brings governance, compliance, and advocacy
            expertise — ensuring the Foundation operates with transparency, accountability, and an unwavering ethical
            foundation.
          </p>
        )}
        <div class="creds reveal reveal-delay-3">
          {(nicole?.credentialTags || monica?.credentialTags) ? (
            [...(nicole?.credentialTags || []), ...(monica?.credentialTags || [])].map((tag) => (
              <span class="cred">{tag}</span>
            ))
          ) : (
            <Fragment>
              <span class="cred">MHA · Master of Healthcare Administration</span>
              <span class="cred">CPSS Certified</span>
              <span class="cred">U.S. Veteran</span>
              <span class="cred">Published Author</span>
              <span class="cred">Attorney-at-Law</span>
            </Fragment>
          )}
        </div>
        <div class="reveal reveal-delay-4">
          <a href="/about" class="btn-bark">{page?.foundersCtaLabel || 'More about our team'} <i data-lucide="arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ DONATE ══ -->
  <section class="donate-section" id="donate">
    <div class="donate-band">
      <div class="donate-left">
        <div class="section-label reveal">{page?.donateLabel || 'Get Involved'}</div>
        <h2 class="donate-title reveal reveal-delay-1" set:html={page?.donateHeading || 'Help a child focus on<br /><em>learning, not hardship.</em>'} />
        <p class="donate-body reveal reveal-delay-2">
          {page?.donateBody || 'Your donation directly funds scholarships, school supplies, and community programs that promote both learning and emotional well-being. Every contribution — large or small — means a child shows up to school with what they need.'}
        </p>
        <div class="donate-actions reveal reveal-delay-3">
          <a href="/donate" class="btn-teal" data-zeffy=""><i data-lucide="heart"></i> {page?.donateCtaLabel || 'Donate now'}</a>
          <a href={amazonLink} target="_blank" rel="noopener noreferrer" class="btn-text-link"><i data-lucide="book-open"></i> {page?.donateBookLabel || 'Buy a book →'}</a>
        </div>
      </div>
      <div class="donate-right">
        {donationReasons.map((reason, i) => (
          <div class={`donate-reason reveal reveal-delay-${i + 1}`}>
            <span class="donate-reason-icon"><i data-lucide={reason.icon}></i></span>
            <div class="donate-reason-text">
              <strong>{reason.title}</strong>
              {reason.description}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ─────────────────────────────────────────
     HERO IMAGE STYLES
  ───────────────────────────────────────── */
  .hero-real-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: inherit;
    position: relative;
    z-index: 1;
  }

  .founder-real-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: inherit;
    display: block;
  }

  .founder-portrait-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--bark-mid);
    line-height: 1.5;
  }

  .founder-portrait-label em {
    font-size: 0.76rem;
    color: var(--bark-light);
    font-style: italic;
    display: block;
    margin-top: 0.1rem;
  }

  /* ─────────────────────────────────────────
     LUCIDE ICON SIZING (page-specific)
  ───────────────────────────────────────── */
  .prog-icon [data-lucide] { width: 32px; height: 32px; stroke: var(--teal-deep); }
  .prog-card-b .prog-icon [data-lucide],
  .prog-card-wash-purple .prog-icon [data-lucide] { stroke: var(--purple); }
  .prog-card-d .prog-icon [data-lucide] { stroke: var(--slate); }
  .prog-card-f .prog-icon [data-lucide] { stroke: var(--teal-deep); }
  .sticker-icon [data-lucide] { width: 26px; height: 26px; stroke: var(--teal-deep); }
  .belize-row-icon [data-lucide] { width: 22px; height: 22px; stroke: var(--teal-deep); }
  .donate-reason-icon [data-lucide] { width: 24px; height: 24px; stroke: var(--teal-deep); }
  .donate-reason:nth-child(2) .donate-reason-icon [data-lucide] { stroke: var(--purple); }
  .donate-reason:nth-child(3) .donate-reason-icon [data-lucide] { stroke: var(--slate); }
  .belize-flag-wrap [data-lucide] { width: 36px; height: 36px; stroke: var(--teal-deep); margin: auto; }
  .cofounder-icon [data-lucide] { width: 14px; height: 14px; stroke: var(--purple); flex-shrink: 0; }
</style>

<style>
  /* ─────────────────────────────────────────
     HERO
  ───────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    padding-top: 80px;
    display: grid;
    grid-template-columns: 55% 45%;
    position: relative;
    overflow: hidden;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--cream);
    z-index: 0;
  }

  .hero-backdrop::after {
    content: '';
    position: absolute;
    bottom: 0; right: 0;
    width: 65%; height: 100%;
    background: var(--sand);
    clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
  }

  .blob-teal {
    position: absolute; width: 380px; height: 380px;
    background: radial-gradient(circle, var(--teal-wash) 0%, transparent 70%);
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    top: 8%; left: -6%; opacity: 0.55;
    animation: blobMorph 12s ease-in-out infinite;
    pointer-events: none;
  }

  .blob-purple {
    position: absolute; width: 260px; height: 260px;
    background: radial-gradient(circle, var(--purple-mist) 0%, transparent 70%);
    border-radius: 40% 60% 45% 55% / 55% 40% 60% 45%;
    bottom: 10%; left: 30%; opacity: 0.5;
    animation: blobMorph 15s ease-in-out infinite reverse;
    pointer-events: none;
  }

  .hero-dots {
    position: absolute; top: 20%; right: 42%;
    width: 120px; height: 160px;
    background-image: radial-gradient(circle, var(--bark-light) 1.5px, transparent 1.5px);
    background-size: 14px 14px;
    opacity: 0.18; pointer-events: none;
  }

  .hero-left {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; justify-content: center;
    padding: 5rem 4rem 5rem 6rem;
  }

  .hero-kicker {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-size: 0.78rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--teal-deep); margin-bottom: 1.8rem;
  }


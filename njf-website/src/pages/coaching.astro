---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Peer Coaching with Nicole Johnson — The N Johnson Foundation" description="Book a one-on-one peer coaching session with Nicole Johnson, MHA — Certified Peer Support Specialist, U.S. Veteran, and published author. Grounded in lived experience and behavioral health expertise.">

  <PageHero
    label="Peer Coaching"
    title="Guidance rooted in <em>lived experience.</em>"
    subtitle="Book a free 30-minute peer coaching session with Nicole Johnson, MHA — Certified Peer Support Specialist, U.S. Veteran, and behavioral health professional."
  />

  <!-- ══ WHAT IS PEER COACHING ══ -->
  <section class="coaching-intro">
    <div class="coaching-intro-inner">
      <div class="coaching-intro-left">
        <div class="section-label reveal">What Is Peer Coaching?</div>
        <h2 class="section-heading reveal reveal-delay-1">
          Not therapy. Not advice. <em>Partnership.</em>
        </h2>
        <p class="body-text reveal reveal-delay-2">
          Peer coaching is a strengths-based, one-on-one conversation grounded in shared human experience. Nicole doesn't sit above you as a clinician — she walks <strong>beside you</strong> as someone who understands struggle, resilience, and the courage it takes to ask for support.
        </p>
        <p class="body-text reveal reveal-delay-3">
          As a <strong>Medi-Cal Certified Peer Support Specialist</strong> with a Master of Healthcare Administration and years in behavioral health, Nicole brings both professional skill and personal depth to every conversation.
        </p>
      </div>
      <div class="coaching-intro-right">
        <div class="coaching-highlight-card reveal reveal-delay-1">
          <i data-lucide="heart-handshake"></i>
          <h3>Lived experience meets professional training</h3>
        </div>
        <div class="coaching-highlight-card reveal reveal-delay-2">
          <i data-lucide="shield-check"></i>
          <h3>Safe, judgment-free, confidential space</h3>
        </div>
        <div class="coaching-highlight-card reveal reveal-delay-3">
          <i data-lucide="sparkles"></i>
          <h3>Strengths-based, not deficit-focused</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FOCUS AREAS ══ -->
  <section class="focus-section">
    <div class="focus-inner">
      <div class="section-label reveal">What We Can Work On</div>
      <h2 class="section-heading reveal reveal-delay-1">Sessions built around <em>your</em> needs.</h2>
      <div class="focus-grid">
        <div class="focus-card reveal reveal-delay-1">
          <div class="focus-icon"><i data-lucide="heart-pulse"></i></div>
          <h3>Emotional Wellness</h3>
          <p>Develop healthy coping strategies, process difficult emotions, and build a foundation for lasting emotional balance.</p>
        </div>
        <div class="focus-card reveal reveal-delay-2">
          <div class="focus-icon"><i data-lucide="shield"></i></div>
          <h3>Healthy Boundaries</h3>
          <p>Learn to set and maintain boundaries that protect your energy — in relationships, at work, and in daily life.</p>
        </div>
        <div class="focus-card reveal reveal-delay-3">
          <div class="focus-icon"><i data-lucide="compass"></i></div>
          <h3>Life Transitions</h3>
          <p>Navigate major changes — career shifts, post-military life, parenthood, or personal reinvention — with grounded support.</p>
        </div>
        <div class="focus-card reveal reveal-delay-1">
          <div class="focus-icon"><i data-lucide="mountain"></i></div>
          <h3>Resilience & Coping</h3>
          <p>Build the inner tools to bounce forward from setbacks, trauma, and daily stress with clarity and strength.</p>
        </div>
        <div class="focus-card reveal reveal-delay-2">
          <div class="focus-icon"><i data-lucide="target"></i></div>
          <h3>Goal Setting</h3>
          <p>Define what matters most to you and create an actionable path forward — with accountability and encouragement built in.</p>
        </div>
        <div class="focus-card reveal reveal-delay-3">
          <div class="focus-icon"><i data-lucide="hand-heart"></i></div>
          <h3>Self-Care & Self-Love</h3>
          <p>Cultivate a practice of caring for yourself that isn't performative — but deeply, genuinely restorative.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ MEET NICOLE ══ -->
  <section class="meet-nicole">
    <div class="meet-nicole-inner">
      <div class="nicole-photo-wrap reveal">
        <img src="/images/founder-nicole.jpg" alt="Nicole Johnson, MHA — Peer Coach and Founder of The N Johnson Foundation" class="nicole-photo" />
      </div>
      <div class="nicole-bio">
        <div class="section-label reveal">Meet Your Coach</div>
        <h2 class="section-heading reveal reveal-delay-1">Nicole Johnson, <em>MHA</em></h2>
        <p class="body-text reveal reveal-delay-2">
          Nicole is a U.S. Veteran, published author, and Certified Peer Support Specialist with a Master of Healthcare Administration. Her years in behavioral health — combined with her own lived experience — give her a rare ability to bridge systems thinking with deep human compassion.
        </p>
        <p class="body-text reveal reveal-delay-3">
          She's walked through adversity, built resilience from the ground up, and now channels that journey into helping others find their footing. Her published novels — centered on themes of resilience and healing — directly fund The N Johnson Foundation's programs in Belize and the U.S.
        </p>
        <div class="nicole-creds reveal reveal-delay-4">
          <span class="cred-tag"><i data-lucide="award"></i> MHA · Healthcare Administration</span>
          <span class="cred-tag"><i data-lucide="badge-check"></i> CPSS Certified</span>
          <span class="cred-tag"><i data-lucide="shield"></i> U.S. Veteran</span>
          <span class="cred-tag"><i data-lucide="book-open"></i> Published Author</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ WHO IT'S FOR ══ -->
  <section class="who-section">
    <div class="who-inner">
      <div class="section-label reveal">Who Is This For?</div>
      <h2 class="section-heading reveal reveal-delay-1">If any of this sounds like you — <em>let's talk.</em></h2>
      <div class="who-grid">
        <div class="who-card reveal reveal-delay-1">
          <span class="who-emoji">🎖️</span>
          <h3>Veterans</h3>
          <p>Transitioning to civilian life, processing service experiences, or simply needing someone who understands.</p>
        </div>
        <div class="who-card reveal reveal-delay-2">
          <span class="who-emoji">👩‍👧‍👦</span>
          <h3>Parents & Caregivers</h3>
          <p>Carrying the weight of caring for others while neglecting your own emotional wellness and boundaries.</p>
        </div>
        <div class="who-card reveal reveal-delay-3">
          <span class="who-emoji">🌱</span>
          <h3>Young Adults</h3>
          <p>Navigating identity, career uncertainty, relationships, and the pressure of "figuring it all out."</p>
        </div>
        <div class="who-card reveal reveal-delay-4">
          <span class="who-emoji">🤝</span>
          <h3>Anyone Seeking Support</h3>
          <p>You don't need a diagnosis or a crisis. If you want a thoughtful conversation with someone who cares — that's enough.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ BOOK A SESSION (CTA + Cal.com) ══ -->
  <section class="booking-section" id="book">
    <div class="booking-inner">
      <div class="booking-content reveal">
        <div class="section-label section-label-dark reveal">Book a Session</div>
        <h2 class="booking-heading reveal reveal-delay-1">
          Your first step is a <em>conversation.</em>
        </h2>
        <p class="booking-desc reveal reveal-delay-2">
          Sessions are <strong>free</strong>, 30 minutes, and completely confidential. No pressure, no commitments — just a genuine conversation about where you are and where you want to be.
        </p>
        <button
          class="btn-book reveal reveal-delay-3"
          data-cal-link="nicole-johnson-peer/30min"
          data-cal-namespace="30min"
          data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
        >
          <i data-lucide="calendar-check"></i>
          Book your free session
        </button>
        <p class="booking-note reveal reveal-delay-4">
          <i data-lucide="clock"></i> 30-minute session · Free · Virtual
        </p>
      </div>
      <div class="booking-visual reveal reveal-delay-2">
        <div class="booking-card">
          <div class="booking-card-top">
            <span class="booking-card-badge">Free</span>
            <h3>Peer Coaching Session</h3>
            <p>with Nicole Johnson, MHA</p>
          </div>
          <div class="booking-card-details">
            <div class="booking-detail">
              <i data-lucide="clock"></i>
              <span>30 minutes</span>
            </div>
            <div class="booking-detail">
              <i data-lucide="video"></i>
              <span>Virtual (video call)</span>
            </div>
            <div class="booking-detail">
              <i data-lucide="lock"></i>
              <span>Confidential & judgment-free</span>
            </div>
            <div class="booking-detail">
              <i data-lucide="heart"></i>
              <span>Peer-based, not clinical</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FAQ ══ -->
  <section class="faq-section">
    <div class="faq-inner">
      <div class="section-label reveal">Common Questions</div>
      <h2 class="section-heading reveal reveal-delay-1">What to <em>know</em> before booking.</h2>
      <div class="faq-grid">
        <details class="faq-item reveal reveal-delay-1">
          <summary>Is this therapy?</summary>
          <p>No. Peer coaching is not therapy, counseling, or clinical treatment. Nicole is a Certified Peer Support Specialist — not a licensed therapist. Sessions are supportive conversations grounded in shared experience, not clinical diagnoses or treatment plans. If you need clinical support, Nicole can help you identify appropriate resources.</p>
        </details>
        <details class="faq-item reveal reveal-delay-2">
          <summary>Is it really free?</summary>
          <p>Yes. Nicole offers these sessions as part of the Foundation's mission to promote emotional wellness. There is no cost, no hidden fees, and no obligation. If you'd like to support the Foundation's work, you're welcome to <a href="/donate">donate</a> — but it's never expected or required.</p>
        </details>
        <details class="faq-item reveal reveal-delay-1">
          <summary>How do I prepare for a session?</summary>
          <p>Just show up as you are. There's no homework, no forms, and no "right way" to do this. If it helps, think about one thing you'd like to talk through — but even that's optional. Nicole will meet you where you are.</p>
        </details>
        <details class="faq-item reveal reveal-delay-2">
          <summary>Who can book a session?</summary>
          <p>Anyone. Veterans, parents, young adults, community members — you don't need a specific background or situation. If you're looking for a thoughtful, empathetic conversation about wellness, boundaries, resilience, or life transitions, this is for you.</p>
        </details>
        <details class="faq-item reveal reveal-delay-1">
          <summary>What happens during the session?</summary>
          <p>Sessions are 30-minute virtual conversations via video call. Nicole will listen, share relevant experiences, ask thoughtful questions, and help you identify next steps — whether that's a coping strategy, a boundary to set, or simply the relief of being heard.</p>
        </details>
        <details class="faq-item reveal reveal-delay-2">
          <summary>Is what I share confidential?</summary>
          <p>Absolutely. Everything discussed stays between you and Nicole. The only exceptions are standard safety protocols — if there's an immediate risk to yourself or others, Nicole is obligated to connect you with appropriate emergency support.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ══ BOTTOM CTA ══ -->
  <section class="coaching-cta">
    <div class="coaching-cta-inner reveal">
      <h2>You don't have to carry it <em>alone.</em></h2>
      <p>One conversation can be the turning point. Book your free session today.</p>
      <button
        class="btn-teal"
        data-cal-link="nicole-johnson-peer/30min"
        data-cal-namespace="30min"
        data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
      >
        <i data-lucide="calendar-check"></i> Book a free session
      </button>
    </div>
  </section>

  <!-- Cal.com embed script -->
  <script is:inline>
  (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
  Cal("init", "30min", {origin:"https://app.cal.com"});
  Cal.ns["30min"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
  </script>

</BaseLayout>

<style>
  [data-lucide] { width: 20px; height: 20px; stroke: currentColor; }

  /* ── SHARED ── */
  .section-heading { font-family: var(--font-serif); font-size: clamp(1.9rem, 3vw, 2.6rem); font-weight: 700; color: var(--bark); line-height: 1.2; letter-spacing: -0.3px; margin-bottom: 1.4rem; }
  .section-heading em { font-style: italic; color: var(--teal-deep); }
  .body-text { font-size: 1rem; color: var(--bark-mid); line-height: 1.8; margin-bottom: 1.2rem; }
  .body-text strong { color: var(--bark); font-weight: 600; }

  /* ── INTRO ── */
  .coaching-intro { padding: 6rem; background: var(--cream); }
  .coaching-intro-inner { max-width: 1050px; margin: 0 auto; display: grid; grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start; }

  .coaching-highlight-card {
    background: var(--sand);
    border-radius: 16px;
    padding: 1.4rem 1.6rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    transition: transform 0.25s;
  }
  .coaching-highlight-card:hover { transform: translateX(4px); }
  .coaching-highlight-card [data-lucide] { width: 24px; height: 24px; stroke: var(--teal-deep); flex-shrink: 0; }
  .coaching-highlight-card h3 { font-family: var(--font-serif); font-size: 0.95rem; font-weight: 600; color: var(--bark); line-height: 1.4; }

  /* ── FOCUS AREAS ── */
  .focus-section { padding: 6rem; background: var(--sand); }
  .focus-inner { max-width: 1000px; margin: 0 auto; }
  .focus-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2.5rem; }
  .focus-card {
    background: var(--cream);
    border-radius: 20px;
    padding: 2rem;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .focus-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(44, 74, 90, 0.08); }
  .focus-icon { margin-bottom: 1rem; }
  .focus-icon [data-lucide] { width: 28px; height: 28px; stroke: var(--teal-deep); }
  .focus-card h3 { font-family: var(--font-serif); font-size: 1.05rem; font-weight: 700; color: var(--bark); margin-bottom: 0.6rem; }
  .focus-card p { font-size: 0.88rem; color: var(--bark-mid); line-height: 1.65; }

  /* ── MEET NICOLE ── */
  .meet-nicole { padding: 6rem; background: var(--cream); }
  .meet-nicole-inner { max-width: 950px; margin: 0 auto; display: grid; grid-template-columns: 280px 1fr; gap: 4rem; align-items: start; }
  .nicole-photo-wrap { border-radius: 24px; overflow: hidden; aspect-ratio: 3 / 4; }
  .nicole-photo { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .nicole-creds { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.2rem; }
  .cred-tag {
    background: var(--teal-mist);
    border: 1px solid var(--teal-wash);
    border-radius: 10px;
    padding: 0.45rem 0.9rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--teal-deep);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .cred-tag [data-lucide] { width: 14px; height: 14px; stroke: var(--teal-deep); }

  /* ── WHO IT'S FOR ── */
  .who-section { padding: 6rem; background: var(--sand); }
  .who-inner { max-width: 900px; margin: 0 auto; }
  .who-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2.5rem; }
  .who-card {
    background: var(--cream);
    border-radius: 20px;
    padding: 2rem;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .who-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(44, 74, 90, 0.08); }
  .who-emoji { font-size: 1.8rem; display: block; margin-bottom: 0.8rem; }
  .who-card h3 { font-family: var(--font-serif); font-size: 1.05rem; font-weight: 700; color: var(--bark); margin-bottom: 0.5rem; }
  .who-card p { font-size: 0.88rem; color: var(--bark-mid); line-height: 1.65; }

  /* ── BOOKING SECTION ── */
  .booking-section { padding: 6rem; background: var(--bark); }
  .booking-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; }
  .booking-heading { font-family: var(--font-serif); font-size: clamp(1.9rem, 3vw, 2.6rem); font-weight: 700; color: var(--cream); line-height: 1.2; letter-spacing: -0.3px; margin-bottom: 1.2rem; }
  .booking-heading em { font-style: italic; color: var(--teal-wash); }
  .booking-desc { font-size: 1rem; color: rgba(253, 250, 246, 0.65); line-height: 1.8; margin-bottom: 2rem; }
  .booking-desc strong { color: var(--teal-wash); font-weight: 600; }

  .btn-book {
    background: var(--teal);
    color: var(--cream);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.1rem 2.5rem;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    box-shadow: 0 6px 24px rgba(46, 169, 155, 0.35);
    transition: background 0.2s, transform 0.2s;
  }
  .btn-book:hover { background: #25917F; transform: translateY(-2px); }
  .btn-book:focus-visible { outline: 2px solid var(--teal-wash); outline-offset: 3px; }
  .btn-book [data-lucide] { width: 20px; height: 20px; }

  .booking-note {
    margin-top: 1.2rem;
    font-size: 0.82rem;
    color: rgba(253, 250, 246, 0.4);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .booking-note [data-lucide] { width: 14px; height: 14px; stroke: rgba(253, 250, 246, 0.35); }

  .booking-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    overflow: hidden;
    backdrop-filter: blur(4px);
  }
  .booking-card-top {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    position: relative;
  }
  .booking-card-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: var(--teal);
    color: var(--cream);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
  }
  .booking-card-top h3 { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 700; color: var(--cream); margin-bottom: 0.3rem; }
  .booking-card-top p { font-size: 0.85rem; color: rgba(253, 250, 246, 0.5); }
  .booking-card-details { padding: 1.5rem 2rem 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .booking-detail {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    color: rgba(253, 250, 246, 0.6);
  }
  .booking-detail [data-lucide] { width: 18px; height: 18px; stroke: var(--teal); flex-shrink: 0; }

  /* ── FAQ ── */
  .faq-section { padding: 6rem; background: var(--cream); }
  .faq-inner { max-width: 750px; margin: 0 auto; }
  .faq-grid { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2rem; }
  .faq-item {
    background: var(--sand);
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.3s;
  }
  .faq-item[open] { box-shadow: 0 4px 20px rgba(44, 74, 90, 0.06); }
  .faq-item summary {
    padding: 1.3rem 1.6rem;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--bark);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    list-style: none;
    transition: color 0.2s;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--teal);
    transition: transform 0.25s;
  }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item summary:hover { color: var(--teal-deep); }
  .faq-item summary:focus-visible { outline: 2px solid var(--teal); outline-offset: -2px; border-radius: 16px; }
  .faq-item p {
    padding: 0 1.6rem 1.4rem;
    font-size: 0.9rem;
    color: var(--bark-mid);
    line-height: 1.75;
  }
  .faq-item p a { color: var(--teal-deep); text-decoration: underline; text-underline-offset: 2px; }
  .faq-item p a:hover { color: var(--teal); }

  /* ── BOTTOM CTA ── */
  .coaching-cta { padding: 5rem; background: var(--teal-mist); text-align: center; }
  .coaching-cta-inner { max-width: 550px; margin: 0 auto; }
  .coaching-cta h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 700; color: var(--bark); line-height: 1.2; margin-bottom: 1rem; }
  .coaching-cta h2 em { font-style: italic; color: var(--teal-deep); }
  .coaching-cta p { font-size: 0.95rem; color: var(--bark-mid); line-height: 1.7; margin-bottom: 2rem; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .coaching-intro, .focus-section, .meet-nicole, .who-section, .booking-section, .faq-section, .coaching-cta { padding: 4rem 2.5rem; }
    .coaching-intro-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .focus-grid { grid-template-columns: 1fr 1fr; }
    .meet-nicole-inner { grid-template-columns: 1fr; text-align: center; }
    .nicole-photo-wrap { max-width: 280px; margin: 0 auto; }
    .nicole-creds { justify-content: center; }
    .who-grid { grid-template-columns: 1fr 1fr; }
    .booking-inner { grid-template-columns: 1fr; gap: 3rem; }
  }

  @media (max-width: 640px) {
    .coaching-intro, .focus-section, .meet-nicole, .who-section, .booking-section, .faq-section, .coaching-cta { padding: 3.5rem 1.5rem; }
    .focus-grid { grid-template-columns: 1fr; }
    .who-grid { grid-template-columns: 1fr; }
    .nicole-photo-wrap { max-width: 220px; }
    .booking-card-top { padding: 1.5rem; }
    .booking-card-details { padding: 1.5rem; }
  }

---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The N Johnson Foundation removes educational and financial barriers for children and families in Belize and the United States.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-G6H8PXCLNT"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-G6H8PXCLNT');
  </script>

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/og_image.png" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- Lucide Icons -->
  <script is:inline src="https://unpkg.com/lucide@latest"></script>
</head>

<body>
  <Nav currentPath={currentPath} />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- Zeffy Donation Modal -->
  <div id="zeffy-modal" class="zeffy-overlay" aria-hidden="true">
    <div class="zeffy-modal-content">
      <button id="zeffy-close" class="zeffy-close" aria-label="Close donation form">&times;</button>
      <iframe
        id="zeffy-iframe"
        title="Donation form powered by Zeffy"
        src="about:blank"
        data-base-src="https://www.zeffy.com/embed/donation-form/donate-to-change-lives-8784"
        allowpaymentrequest
        allowTransparency="true"
      ></iframe>
    </div>
  </div>

  <script is:inline>
    // Initialise Lucide icons
    lucide.createIcons();

    // Nav ink on scroll
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('inked', window.scrollY > 24);
    }, { passive: true });

    // Scroll reveal
    const revealEls = document.querySelectorAll('.reveal');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(el => revealObserver.observe(el));

    // Zeffy donation popup
    const zeffyModal = document.getElementById('zeffy-modal');
    const zeffyIframe = document.getElementById('zeffy-iframe');
    const zeffyClose = document.getElementById('zeffy-close');
    const baseSrc = zeffyIframe.getAttribute('data-base-src');

    function openZeffy(amount) {
      const src = amount ? baseSrc + '?amount=' + amount : baseSrc;
      zeffyIframe.src = src;
      zeffyModal.classList.add('active');
      zeffyModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeZeffy() {
      zeffyModal.classList.remove('active');
      zeffyModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(function() { zeffyIframe.src = 'about:blank'; }, 300);
    }

    zeffyClose.addEventListener('click', closeZeffy);
    zeffyModal.addEventListener('click', function(e) {
      if (e.target === zeffyModal) closeZeffy();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && zeffyModal.classList.contains('active')) closeZeffy();
    });

    // Any link/button with data-zeffy opens the popup
    document.querySelectorAll('[data-zeffy]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.preventDefault();
        openZeffy(el.getAttribute('data-zeffy'));
      });
    });
  </script>
</body>
</html>
